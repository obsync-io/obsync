<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Palette (calm enterprise — exact spec colors) ============ -->
    <Color x:Key="AppBackgroundColor">#F8FAFC</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="PanelColor">#F1F5F9</Color>
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <Color x:Key="TextMutedColor">#6B7280</Color>
    <!-- Brand blue (matches the Obsync logo/icon). -->
    <Color x:Key="AccentColor">#1B17FF</Color>
    <Color x:Key="AccentHoverColor">#1512D6</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="ErrorColor">#DC2626</Color>

    <!-- Soft tints for small status/change badges (calm, low-saturation) -->
    <Color x:Key="SuccessSoftColor">#E7F5EC</Color>
    <Color x:Key="WarningSoftColor">#FBF0E1</Color>
    <Color x:Key="ErrorSoftColor">#FBE9E9</Color>
    <Color x:Key="AccentSoftColor">#EBEAFF</Color>
    <Color x:Key="NeutralSoftColor">#F1F5F9</Color>
    <Color x:Key="RowHoverColor">#F8FAFC</Color>

    <!-- Diff word-level highlights: stronger than the soft line tints so intra-line changes pop. -->
    <Color x:Key="DiffAddedEmphasisColor">#BFE8CD</Color>
    <Color x:Key="DiffDeletedEmphasisColor">#F5C8C8</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource WarningSoftColor}" />
    <SolidColorBrush x:Key="ErrorSoftBrush" Color="{StaticResource ErrorSoftColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="NeutralSoftBrush" Color="{StaticResource NeutralSoftColor}" />
    <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHoverColor}" />

    <SolidColorBrush x:Key="DiffAddedEmphasisBrush" Color="{StaticResource DiffAddedEmphasisColor}" />
    <SolidColorBrush x:Key="DiffDeletedEmphasisBrush" Color="{StaticResource DiffDeletedEmphasisColor}" />

    <!-- Scrollbar thumb: quiet at rest, slightly darker under the pointer / while dragging. -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#C9CED6" />
    <SolidColorBrush x:Key="ScrollThumbActiveBrush" Color="#A8AFBA" />

    <!-- ============ Tokens ============ -->
    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusControl">6</CornerRadius>
    <CornerRadius x:Key="RadiusCard">10</CornerRadius>
    <CornerRadius x:Key="RadiusPill">12</CornerRadius>

    <!-- Spacing (use as Thickness where a uniform gap is needed) -->
    <Thickness x:Key="PagePadding">28,24</Thickness>
    <Thickness x:Key="CardPadding">20</Thickness>

</ResourceDictionary>
