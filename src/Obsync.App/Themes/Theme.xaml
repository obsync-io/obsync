<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- The Obsync design system, split for clarity. Order matters: Controls references
         tokens/brushes/typography/icons from the dictionaries merged before it. -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
        <ResourceDictionary Source="Typography.xaml" />
        <ResourceDictionary Source="Icons.xaml" />
        <ResourceDictionary Source="Controls.xaml" />
        <ResourceDictionary Source="BrandLogo.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
