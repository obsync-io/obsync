<Application x:Class="Obsync.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Obsync.App.ViewModels"
             xmlns:views="clr-namespace:Obsync.App.Views"
             xmlns:conv="clr-namespace:Obsync.App.Converters"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             DispatcherUnhandledException="OnDispatcherUnhandledException">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:StatusToBrushConverter x:Key="StatusToBrush" />
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
            <conv:StatusToBadgeBackgroundConverter x:Key="StatusToBadgeBackground" />
            <conv:StatusToTextConverter x:Key="StatusToText" />
            <conv:ChangeTypeToBrushConverter x:Key="ChangeTypeToBrush" />
            <conv:ChangeTypeToBadgeBackgroundConverter x:Key="ChangeTypeToBadgeBackground" />
            <conv:DiffRowKindToBackgroundConverter x:Key="DiffRowBackground" />
            <conv:MsToDurationConverter x:Key="MsToDuration" />
            <conv:LocalDateTimeConverter x:Key="LocalDateTime" />
            <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
            <conv:SectionToBoolConverter x:Key="SectionToBool" />
            <conv:EnumDisplayConverter x:Key="EnumDisplay" />
            <conv:ConnectionStatusToTextConverter x:Key="ConnectionStatusToText" />
            <conv:ConnectionStatusToBrushConverter x:Key="ConnectionStatusToBrush" />
            <conv:ConnectionStatusToBadgeBackgroundConverter x:Key="ConnectionStatusToBadgeBackground" />
            <conv:OverdueDetailConverter x:Key="OverdueDetail" />

            <!-- Job-list action glyphs (same Fluent set as Themes/Icons.xaml). -->
            <sys:String x:Key="IconPause">&#xE769;</sys:String>
            <sys:String x:Key="IconMore">&#xE712;</sys:String>

            <!-- Reusable small status badge (DataContext = RunStatus, or null for a never-run job).
                 FallbackValue covers the null-content case, where the empty-path binding yields
                 UnsetValue and the converter is skipped — the badge then reads as a neutral "Not run". -->
            <DataTemplate x:Key="StatusBadgeTemplate">
                <Border CornerRadius="{StaticResource RadiusPill}" Padding="9,3" HorizontalAlignment="Left"
                        Background="{Binding Converter={StaticResource StatusToBadgeBackground}, FallbackValue={StaticResource NeutralSoftBrush}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center"
                                 Fill="{Binding Converter={StaticResource StatusToBrush}, FallbackValue={StaticResource TextMutedBrush}}" />
                        <TextBlock Text="{Binding Converter={StaticResource StatusToText}, FallbackValue=Not run}" FontSize="12"
                                   FontWeight="SemiBold" Foreground="{Binding Converter={StaticResource StatusToBrush}, FallbackValue={StaticResource TextMutedBrush}}" />
                    </StackPanel>
                </Border>
            </DataTemplate>

            <!-- Job status badge for the Dashboard/Jobs tables (DataContext = SyncJob): the last
                 run's status via StatusBadgeTemplate, or a neutral "Paused" badge when the schedule
                 is disabled and no run is in progress — pausing must read as deliberate, not as an
                 outcome, so it never reuses a RunStatus colour. -->
            <DataTemplate x:Key="JobStatusBadgeTemplate">
                <Grid>
                    <ContentControl x:Name="RunBadge" Content="{Binding DisplayStatus}"
                                    ContentTemplate="{StaticResource StatusBadgeTemplate}" />
                    <Border x:Name="PausedBadge" Visibility="Collapsed" CornerRadius="{StaticResource RadiusPill}"
                            Padding="9,3" HorizontalAlignment="Left" Background="{StaticResource NeutralSoftBrush}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="Paused" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                        <Setter TargetName="RunBadge" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="PausedBadge" Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <!-- Next-run cell for the Dashboard/Jobs tables (DataContext = SyncJob): the plain local
                 timestamp, replaced by an amber dot + "Overdue" (text, never colour alone) with the
                 scheduled time and corrective hint in the tooltip when the run has not started. -->
            <DataTemplate x:Key="NextRunCellTemplate">
                <Grid>
                    <TextBlock x:Name="Stamp" Text="{Binding RunSummary.NextRunAt, Converter={StaticResource LocalDateTime}}"
                               Style="{StaticResource Muted}" VerticalAlignment="Center" TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel x:Name="Overdue" Orientation="Horizontal" Visibility="Collapsed"
                                ToolTip="{Binding RunSummary.NextRunAt, Converter={StaticResource OverdueDetail}}">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center"
                                 Fill="{StaticResource WarningBrush}" />
                        <TextBlock Text="Overdue" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                        <Setter TargetName="Stamp" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="Overdue" Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <!-- Reusable change-type badge (DataContext = ChangeType). -->
            <DataTemplate x:Key="ChangeBadgeTemplate">
                <Border CornerRadius="{StaticResource RadiusPill}" Padding="9,3" HorizontalAlignment="Left"
                        Background="{Binding Converter={StaticResource ChangeTypeToBadgeBackground}}">
                    <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding Converter={StaticResource ChangeTypeToBrush}}" />
                </Border>
            </DataTemplate>

            <!-- Server connection status badge (DataContext = ConnectionTestStatus). -->
            <DataTemplate x:Key="ConnectionStatusBadgeTemplate">
                <Border CornerRadius="{StaticResource RadiusPill}" Padding="9,3" HorizontalAlignment="Left"
                        Background="{Binding Converter={StaticResource ConnectionStatusToBadgeBackground}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center"
                                 Fill="{Binding Converter={StaticResource ConnectionStatusToBrush}}" />
                        <TextBlock Text="{Binding Converter={StaticResource ConnectionStatusToText}}" FontSize="12"
                                   FontWeight="SemiBold" Foreground="{Binding Converter={StaticResource ConnectionStatusToBrush}}" />
                    </StackPanel>
                </Border>
            </DataTemplate>

            <!-- Environment tag chip (DataContext = TagChip). Production tags read red. -->
            <DataTemplate x:Key="TagChipTemplate">
                <Border CornerRadius="{StaticResource RadiusPill}" Padding="8,2" Margin="0,4,6,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource NeutralSoftBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProduction}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ErrorSoftBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <!-- Trim rather than clip when a narrow tags column constrains the chip. -->
                    <TextBlock Text="{Binding Text}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProduction}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </DataTemplate>

            <!-- Reusable horizontal chip list (ItemsSource = a TagChip collection). -->
            <Style x:Key="TagChipsList" TargetType="ItemsControl">
                <Setter Property="ItemTemplate" Value="{StaticResource TagChipTemplate}" />
                <Setter Property="ItemsPanel">
                    <Setter.Value>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ViewModel -> View mapping (MVVM, no code-behind navigation) -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:JobsViewModel}">
                <views:JobsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:JobDetailViewModel}">
                <views:JobDetailView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ServersViewModel}">
                <views:ServersView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RepositoriesViewModel}">
                <views:RepositoriesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                <views:HistoryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
