<Window x:Class="Obsync.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obsync" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Obsync.App;component/Assets/Obsync_Icon.png"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        MinWidth="960" MinHeight="600"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="224" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left navigation rail -->
        <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand block: icon mark + wordmark (no tagline). -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="22,24,20,26" VerticalAlignment="Center">
                    <Image Source="/Assets/Obsync_Icon.png" Width="32" Height="32"
                           RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" />
                    <Image Source="{StaticResource ObsyncWordmark}" Height="20" Margin="11,0,0,0"
                           VerticalAlignment="Center" Stretch="Uniform" />
                </StackPanel>

                <!-- Navigation items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 IsChecked="{Binding CurrentSection, Converter={StaticResource SectionToBool}, ConverterParameter=Dashboard, Mode=TwoWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconDashboard}" Width="20" HorizontalAlignment="Left" />
                            <TextBlock Text="Dashboard" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 IsChecked="{Binding CurrentSection, Converter={StaticResource SectionToBool}, ConverterParameter=Servers, Mode=TwoWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Servers">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconConnections}" Width="20" HorizontalAlignment="Left" />
                            <TextBlock Text="Servers" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 IsChecked="{Binding CurrentSection, Converter={StaticResource SectionToBool}, ConverterParameter=Repositories, Mode=TwoWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Repositories">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRepositories}" Width="20" HorizontalAlignment="Left" />
                            <TextBlock Text="Repositories" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 IsChecked="{Binding CurrentSection, Converter={StaticResource SectionToBool}, ConverterParameter=Jobs, Mode=TwoWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Jobs">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconJobs}" Width="20" HorizontalAlignment="Left" />
                            <TextBlock Text="Jobs" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 IsChecked="{Binding CurrentSection, Converter={StaticResource SectionToBool}, ConverterParameter=History, Mode=TwoWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="History">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconHistory}" Width="20" HorizontalAlignment="Left" />
                            <TextBlock Text="History" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 IsChecked="{Binding CurrentSection, Converter={StaticResource SectionToBool}, ConverterParameter=Settings, Mode=TwoWay}"
                                 Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconSettings}" Width="20" HorizontalAlignment="Left" />
                            <TextBlock Text="Settings" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0" />

        <!-- In-app notifications (bottom-right, above the content) -->
        <ItemsControl Grid.Column="1" ItemsSource="{Binding Toasts}" Panel.ZIndex="100"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24"
                      IsTabStop="False">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="380" Margin="0,10,0,0" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusCard}" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Severity bar: red for failures, amber for warnings, accent for info -->
                            <Border Grid.Column="0" CornerRadius="10,0,0,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInfo}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <TextBlock Grid.Column="1" FontFamily="{StaticResource IconFontFamily}" FontSize="18"
                                       VerticalAlignment="Top" Margin="14,15,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{StaticResource IconWarning}" />
                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Text" Value="{StaticResource IconError}" />
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInfo}" Value="True">
                                                <Setter Property="Text" Value="{StaticResource IconUpdate}" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <StackPanel Grid.Column="2" Margin="12,12,4,12">
                                <TextBlock Text="{Binding Title}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Message}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,2,0,6" />
                                <Button Style="{StaticResource LinkButton}" Content="{Binding ActionText}" HorizontalAlignment="Left"
                                        Command="{Binding DataContext.OpenToastCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>

                            <Button Grid.Column="3" Style="{StaticResource IconButton}" ToolTip="Dismiss"
                                    AutomationProperties.Name="Dismiss notification"
                                    VerticalAlignment="Top" Margin="0,8,8,0"
                                    Command="{Binding DataContext.DismissToastCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconClose}" FontSize="12" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
