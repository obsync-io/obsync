<UserControl x:Class="Obsync.App.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- A full-width clickable row inside a timeline entry's change list. -->
        <Style x:Key="TimelineChangeRow" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="History" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Runs, commits, and changed objects" Style="{StaticResource Muted}" Margin="0,4,0,18" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right" MaxWidth="420">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"
                            Command="{Binding ViewChangesCommand}"
                            ToolTip="View the scripts that changed in the selected run">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconDiff}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="View changes" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportReportCommand}" ToolTip="Export the selected run as HTML, CSV, or JSON">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconExport}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Export report" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Style="{StaticResource Muted}" Text="{Binding ReportMessage}" Margin="0,8,0,0"
                           TextWrapping="Wrap" TextAlignment="Right"
                           Visibility="{Binding ReportMessage, Converter={StaticResource NullToVisibility}}" />
            </StackPanel>
        </Grid>

        <!-- Filter bar (hidden until there is anything to filter) -->
        <Grid Grid.Row="1" Margin="0,0,0,16"
              Visibility="{Binding Runs.Count, Converter={StaticResource CountToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0" ItemsSource="{Binding JobNames}" SelectedItem="{Binding SelectedJob}" Margin="0,0,10,0" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}"
                      DisplayMemberPath="Label" Margin="0,0,10,0" />
            <TextBox Grid.Column="2" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Search by job name, commit SHA, database, or who triggered the run">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Resources>
                            <VisualBrush x:Key="SearchHint" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                <VisualBrush.Visual>
                                    <TextBlock Text="Search job, commit, database, or user…" Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="{StaticResource AppFontFamily}" FontSize="13" Margin="10,0,0,0" />
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{StaticResource SearchHint}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>

        <TabControl Grid.Row="2" Visibility="{Binding Runs.Count, Converter={StaticResource CountToVisibility}}">
            <TabItem Header="Runs">
        <DockPanel Margin="0,14,0,0">
            <!-- The load is capped; older runs are still in the database -->
            <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Caption}" Margin="2,8,0,0" TextWrapping="Wrap"
                       Text="Showing the 100 most recent runs — export a run report or use filters for older history."
                       Visibility="{Binding IsCapped, Converter={StaticResource BoolToVisibility}}" />
        <Border Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding RunsView}" SelectedItem="{Binding SelectedRun}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Job" Binding="{Binding JobName}" Width="2*" MinWidth="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="ToolTip" Value="{Binding JobName}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Tags" Width="1.3*" MinWidth="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding TagChips}" Style="{StaticResource TagChipsList}" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Run time" Binding="{Binding StartedAt, Converter={StaticResource LocalDateTime}}" Width="1.6*" MinWidth="130" />
                    <DataGridTextColumn Header="Duration" Binding="{Binding DurationMs, Converter={StaticResource MsToDuration}}" Width="*" MinWidth="70" />
                    <DataGridTextColumn Header="Scanned" Binding="{Binding ObjectsScanned}" Width="*" MinWidth="64" />
                    <DataGridTextColumn Header="Changed" Binding="{Binding ChangeCount}" Width="*" MinWidth="64" />
                    <DataGridTemplateColumn Header="Skipped" Width="*" MinWidth="72">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!-- Only rendered when objects could not be scripted -->
                                <TextBlock Text="{Binding ObjectsFailed, StringFormat={}{0:N0} skipped}"
                                           Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" VerticalAlignment="Center"
                                           ToolTip="Objects that could not be scripted — open the job's Logs tab for the list">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ObjectsFailed}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Commit" Binding="{Binding CommitSha}" Width="1.4*" MinWidth="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="ToolTip" Value="{Binding CommitSha}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Status" Width="1.2*" MinWidth="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding Status}" ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                                VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        </DockPanel>
            </TabItem>

            <TabItem Header="Timeline">
                <Grid Margin="0,14,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding TimelineDays.Count, Converter={StaticResource CountToVisibility}}">
                        <ItemsControl ItemsSource="{Binding TimelineDays}" Margin="0,0,12,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- One day -->
                                    <StackPanel Margin="0,0,0,18">
                                        <Grid Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DateLabel}" Style="{StaticResource SectionTitle}" />
                                                <TextBlock Text="{Binding RunsLabel}" Style="{StaticResource Muted}" Margin="12,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <!-- Day change totals (each hidden when zero) -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="no changes" Style="{StaticResource Muted}"
                                                           Visibility="{Binding HasNoChanges, Converter={StaticResource BoolToVisibility}}" />
                                                <TextBlock Text="{Binding Added, StringFormat=+{0:N0}}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" Margin="10,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Added}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Modified, StringFormat=~{0:N0}}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" Margin="10,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Modified}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Deleted, StringFormat=&#x2212;{0:N0}}" Foreground="{StaticResource ErrorBrush}" FontWeight="SemiBold" Margin="10,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Deleted}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <!-- The day's runs on a rail -->
                                        <ItemsControl ItemsSource="{Binding Entries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="26" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Rail: line + status dot -->
                                                        <Border Grid.Column="0" Width="2" Background="{StaticResource BorderBrush}" HorizontalAlignment="Center" />
                                                        <Ellipse Grid.Column="0" Width="11" Height="11" VerticalAlignment="Top" Margin="0,16,0,0"
                                                                 Stroke="{StaticResource AppBackgroundBrush}" StrokeThickness="2">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Run.Status}" Value="Succeeded">
                                                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Run.Status}" Value="Warning">
                                                                            <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Run.Status}" Value="Failed">
                                                                            <Setter Property="Fill" Value="{StaticResource ErrorBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Run.Status}" Value="NoChanges">
                                                                            <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Run.Status}" Value="Cancelled">
                                                                            <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>

                                                        <!-- Entry card -->
                                                        <Border Grid.Column="1" CornerRadius="10" BorderThickness="1" Padding="16,12" Margin="0,0,0,10" Cursor="Hand">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.SelectEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Border.InputBindings>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource CardBrush}" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
                                                                        </Trigger>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Column="0" Text="{Binding TimeLabel}" Style="{StaticResource Muted}"
                                                                               VerticalAlignment="Center" MinWidth="58" />

                                                                    <StackPanel Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Run.JobName}" Style="{StaticResource BodyStrong}" TextTrimming="CharacterEllipsis" />
                                                                            <ItemsControl ItemsSource="{Binding Run.TagChips}" Style="{StaticResource TagChipsList}"
                                                                                          Margin="8,0,0,0" VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding ContextLabel}" Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis"
                                                                                   ToolTip="{Binding ContextLabel}" Margin="0,2,0,0" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <!-- Per-run change counts (hidden when zero) -->
                                                                        <TextBlock Text="{Binding Run.ObjectsAdded, StringFormat=+{0:N0}}" Foreground="{StaticResource SuccessBrush}"
                                                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Run.ObjectsAdded}" Value="0">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding Run.ObjectsModified, StringFormat=~{0:N0}}" Foreground="{StaticResource WarningBrush}"
                                                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Run.ObjectsModified}" Value="0">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding Run.ObjectsDeleted, StringFormat=&#x2212;{0:N0}}" Foreground="{StaticResource ErrorBrush}"
                                                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Run.ObjectsDeleted}" Value="0">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>

                                                                        <TextBlock Text="{Binding Run.CommitSha}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12"
                                                                                   Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0"
                                                                                   MaxWidth="72" TextTrimming="CharacterEllipsis" ToolTip="{Binding Run.CommitSha}"
                                                                                   Visibility="{Binding Run.CommitSha, Converter={StaticResource NullToVisibility}}" />

                                                                        <ContentControl Content="{Binding Run.Status}" ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                                                                        VerticalAlignment="Center" ToolTip="{Binding Run.ErrorMessage}" />

                                                                        <Button Style="{StaticResource IconButton}" Margin="8,0,0,0"
                                                                                ToolTip="View changed scripts" AutomationProperties.Name="View changed scripts"
                                                                                Command="{Binding DataContext.ViewEntryChangesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Visibility="{Binding Run.CommitSha, Converter={StaticResource NullToVisibility}}">
                                                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconDiff}" />
                                                                        </Button>

                                                                        <Button Style="{StaticResource IconButton}" Margin="2,0,0,0"
                                                                                ToolTip="Show changed objects" AutomationProperties.Name="Show changed objects"
                                                                                Command="{Binding DataContext.ToggleEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Visibility="{Binding CanExpand, Converter={StaticResource BoolToVisibility}}">
                                                                            <TextBlock>
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Icon}">
                                                                                        <Setter Property="Text" Value="{StaticResource IconChevronDown}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                                <Setter Property="Text" Value="{StaticResource IconChevronUp}" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <TextBlock Text="Loading changes…" Style="{StaticResource Caption}" Margin="0,10,0,0"
                                                                           Visibility="{Binding IsLoadingChanges, Converter={StaticResource BoolToVisibility}}" />

                                                                <!-- Changed objects (lazy, capped) -->
                                                                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="6" Margin="0,10,0,0"
                                                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                                    <StackPanel>
                                                                        <ItemsControl ItemsSource="{Binding Changes}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Button Style="{StaticResource TimelineChangeRow}"
                                                                                            ToolTip="Open in the diff viewer"
                                                                                            Command="{Binding DataContext.OpenTimelineChangeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                            CommandParameter="{Binding}">
                                                                                        <Grid>
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="86" />
                                                                                                <ColumnDefinition Width="*" />
                                                                                                <ColumnDefinition Width="Auto" />
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <ContentControl Grid.Column="0" Content="{Binding Change.ChangeType}"
                                                                                                            ContentTemplate="{StaticResource ChangeBadgeTemplate}"
                                                                                                            HorizontalAlignment="Left" VerticalAlignment="Center" />
                                                                                            <TextBlock Grid.Column="1" Text="{Binding Change.QualifiedName}" VerticalAlignment="Center"
                                                                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding Change.RelativePath}" Margin="8,0" />
                                                                                            <TextBlock Grid.Column="2" Text="{Binding Change.ObjectType, Converter={StaticResource EnumDisplay}}"
                                                                                                       Style="{StaticResource Muted}" VerticalAlignment="Center" />
                                                                                        </Grid>
                                                                                    </Button>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                        <TextBlock Text="{Binding TruncationNotice}" Style="{StaticResource Caption}" Margin="10,6,10,4" TextWrapping="Wrap"
                                                                                   Visibility="{Binding TruncationNotice, Converter={StaticResource NullToVisibility}}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Filters matched nothing -->
                    <TextBlock Text="No runs match the current filters."
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TimelineDays.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Empty state (shown only when there are no runs) -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Runs.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center">
                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconHistory}" FontSize="24" Foreground="{StaticResource TextMutedBrush}" />
            </Border>
            <TextBlock Text="No runs yet" Style="{StaticResource SectionTitle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0" />
            <TextBlock Text="Run history appears here after a sync job runs." Style="{StaticResource Muted}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
