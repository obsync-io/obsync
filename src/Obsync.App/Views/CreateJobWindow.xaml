<Window x:Class="Obsync.App.Views.CreateJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="760" Width="760"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/Obsync_Icon.png"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource AppFontFamily}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" />
            <TextBlock Text="{Binding StepCaption}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Stepper -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20,18" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Node 1 · Source -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="1" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Source" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                </StackPanel>

                <Border Grid.Column="1" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 2 · Objects -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="2" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Objects" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="3" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 3 · Destination -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="3" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Destination" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="5" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 4 · Schedule -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="4" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Schedule" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="7" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 5 · Review -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="5" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Review" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Step 1 · Source -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Source" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="Where to read objects from." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <TextBlock Text="JOB NAME" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

                        <TextBlock Text="SQL CONNECTION" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding Connections}" SelectedItem="{Binding SelectedConnection}"
                                  DisplayMemberPath="Name" Margin="0,4,0,10" />
                        <Button Content="Load databases" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Command="{Binding LoadDatabasesCommand}" Margin="0,0,0,16" />

                        <TextBlock Text="DATABASES" Style="{StaticResource Caption}" />
                        <Border Style="{StaticResource Panel}" MaxHeight="240" Margin="0,4,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Databases}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,4" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 2 · Objects -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Objects" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="Choose which database objects to version." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <TextBlock Text="PRESET" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" Margin="0,4,0,0" />

                        <StackPanel Visibility="{Binding IsCustomPreset, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="OBJECT TYPES" Style="{StaticResource Caption}" Margin="0,18,0,0" />
                            <Border Style="{StaticResource Panel}" MaxHeight="320" Margin="0,4,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ObjectTypes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Step 3 · Destination -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Destination" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="Where committed scripts are written." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <TextBlock Text="GITHUB REPOSITORY" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding Repositories}" SelectedItem="{Binding SelectedRepository}"
                                  DisplayMemberPath="FullName" Margin="0,4,0,16" />

                        <TextBlock Text="BRANCH" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding Branch, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

                        <TextBlock Text="DESTINATION FOLDER" Style="{StaticResource Caption}" />
                        <TextBlock Text="Blank = environments/&lt;server&gt;/&lt;database&gt;" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                        <TextBox Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

                        <TextBlock Text="LOCAL EXPORT PATH (OPTIONAL)" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding LocalExportPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Step 4 · Schedule -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep4, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Schedule" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="How often this job runs." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <TextBlock Text="CADENCE" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding ScheduleKinds}" SelectedItem="{Binding SelectedScheduleKind}" Margin="0,4,0,16" />

                        <StackPanel Visibility="{Binding ShowHourly, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="EVERY N HOURS" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding IntervalHours, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowDayTime, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="TIME OF DAY (HH:MM)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding TimeOfDay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowWeekday, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="DAY OF WEEK" Style="{StaticResource Caption}" />
                            <ComboBox ItemsSource="{Binding DaysOfWeek}" SelectedItem="{Binding SelectedDayOfWeek}" Margin="0,4,0,16" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowCron, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="CRON EXPRESSION (QUARTZ 7-FIELD)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding CronExpression, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                        </StackPanel>

                        <Border Style="{StaticResource Divider}" />
                        <CheckBox Content="Also run once on app/service startup" IsChecked="{Binding RunOnStartup}" Margin="0,2,0,8" />
                        <CheckBox Content="Commit only when changes are detected" IsChecked="{Binding RunOnlyIfChanges}" Margin="0,0,0,2" />
                    </StackPanel>
                </Border>

                <!-- Step 5 · Review -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep5, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Review" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="Confirm the configuration before saving." Style="{StaticResource Caption}" Margin="0,0,0,16" />

                        <Border Style="{StaticResource Panel}" Padding="18,14">
                            <ItemsControl ItemsSource="{Binding ReviewItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource Caption}" VerticalAlignment="Top" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,18,0,0">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" VerticalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="340" HorizontalAlignment="Left" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource SubtleButton}" Click="OnCancel" Margin="0,0,8,0" />
                <Button Content="Back" Style="{StaticResource SecondaryButton}" Command="{Binding BackCommand}"
                        Margin="0,0,8,0" Visibility="{Binding ShowBack, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Next" Style="{StaticResource PrimaryButton}" Command="{Binding NextCommand}"
                        Visibility="{Binding ShowNext, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Save Job" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}"
                        Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
