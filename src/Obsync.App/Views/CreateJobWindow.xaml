<Window x:Class="Obsync.App.Views.CreateJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="760" Width="760"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Obsync.App;component/Assets/Obsync_Icon.png"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" />
            <TextBlock Text="{Binding StepCaption}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Stepper -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20,18" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Node 1 · Source -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            AutomationProperties.Name="Step 1: Source">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="1" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Source" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                </StackPanel>

                <Border Grid.Column="1" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 2 · Objects -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            AutomationProperties.Name="Step 2: Objects">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="2" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Objects" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="2"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="3" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 3 · Destination -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                            AutomationProperties.Name="Step 3: Destination">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="3" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Destination" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="3"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="5" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 4 · Schedule -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center"
                            AutomationProperties.Name="Step 4: Schedule">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="4" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{StaticResource IconCheck}" FontFamily="{StaticResource IconFontFamily}" FontSize="14"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Schedule" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="4"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="7" Height="2" Margin="12,0" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BorderBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Node 5 · Review -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center"
                            AutomationProperties.Name="Step 5: Review">
                    <Grid Width="30" Height="30">
                        <Border CornerRadius="15" BorderThickness="1.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="5" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Review" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="SemiBold" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Step 1 · Source -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Source" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="Where to read objects from." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <TextBlock Text="JOB NAME" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

                        <TextBlock Text="TAGS (COMMA-SEPARATED, OPTIONAL)" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,2"
                                 ToolTip="Environment tags, e.g. prod, finance. A production tag prompts before a manual run." />
                        <TextBlock Text="A tag matching the production list (Settings) shows red and confirms before a manual run."
                                   Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,16" />

                        <TextBlock Text="SERVER" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding Connections}" SelectedItem="{Binding SelectedConnection}"
                                  DisplayMemberPath="Name" Margin="0,4,0,2" />
                        <TextBlock Text="{Binding WindowsAuthNotice}" Style="{StaticResource Caption}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                   Visibility="{Binding WindowsAuthNotice, Converter={StaticResource NullToVisibility}}" />
                        <Button Content="Load databases" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Command="{Binding LoadDatabasesCommand}" Margin="0,8,0,16"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

                        <TextBlock Text="DATABASE SCOPE" Style="{StaticResource Caption}" />
                        <CheckBox Content="Sync all user databases on this server"
                                  IsChecked="{Binding SyncAllUserDatabases}" Margin="0,6,0,2" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,4"
                                   Visibility="{Binding SyncAllUserDatabases, Converter={StaticResource BoolToVisibility}}"
                                   Text="Databases created later are included automatically. System databases are always excluded. A database that is offline or inaccessible is skipped with a warning; it does not fail the run." />
                        <TextBlock Text="{Binding DatabasesHint}" Style="{StaticResource Caption}"
                                   TextWrapping="Wrap" Margin="0,0,0,14" />

                        <TextBlock Text="{Binding DatabasesHeader}" Style="{StaticResource Caption}" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding DatabaseFilter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Filter the database list (contains, case-insensitive)"
                                     AutomationProperties.Name="Filter databases" />
                            <Button Grid.Column="1" Content="Select all" Style="{StaticResource LinkButton}"
                                    Margin="12,0,0,0" VerticalAlignment="Center"
                                    Command="{Binding SelectAllDatabasesCommand}"
                                    ToolTip="Check every database the filter currently shows"
                                    AutomationProperties.Name="Select all filtered databases" />
                            <Button Grid.Column="2" Content="Clear" Style="{StaticResource LinkButton}"
                                    Margin="12,0,0,0" VerticalAlignment="Center"
                                    Command="{Binding ClearDatabaseSelectionCommand}"
                                    ToolTip="Uncheck every database the filter currently shows"
                                    AutomationProperties.Name="Clear filtered database selection" />
                        </Grid>
                        <Border Style="{StaticResource Panel}" MaxHeight="240" Margin="0,6,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DatabasesView}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,4" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 2 · Objects -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Objects" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="Choose which database objects to version." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <TextBlock Text="PRESET" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" Margin="0,4,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <CheckBox Content="View included object types" IsChecked="{Binding ShowPresetContents}" Margin="0,10,0,0" />
                        <TextBlock Text="{Binding PresetContents}" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Visibility="{Binding ShowPresetContents, Converter={StaticResource BoolToVisibility}}" />

                        <StackPanel Visibility="{Binding IsCustomPreset, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="OBJECT TYPES" Style="{StaticResource Caption}" Margin="0,18,0,0" />
                            <Border Style="{StaticResource Panel}" MaxHeight="320" Margin="0,4,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ObjectTypes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="SCHEMA FILTER (COMMA-SEPARATED, OPTIONAL)" Style="{StaticResource Caption}" Margin="0,18,0,0" />
                        <TextBox Text="{Binding SchemaFilter, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,2"
                                 ToolTip="Only these schemas are scripted, e.g. dbo, sales. Leave empty for all schemas." />
                        <TextBlock Text="Empty = all schemas. Useful on multi-tenant servers to version only the schemas you own."
                                   Style="{StaticResource Caption}" TextWrapping="Wrap" />

                        <Border Style="{StaticResource Divider}" Margin="0,20,0,16" />

                        <CheckBox Content="Version server-level objects (logins, Agent jobs, linked servers…)"
                                  IsChecked="{Binding IncludeServerObjects}" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Text="Instance-scoped objects are scripted into a server/ folder. Login scripts document existence and role membership — never real passwords." />

                        <StackPanel Visibility="{Binding IncludeServerObjects, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="SERVER OBJECT TYPES" Style="{StaticResource Caption}" Margin="0,14,0,0" />
                            <Border Style="{StaticResource Panel}" MaxHeight="240" Margin="0,4,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ServerObjectTypes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <Border Style="{StaticResource Divider}" Margin="0,20,0,16" />

                        <CheckBox Content="Version reference data (INSERT scripts)"
                                  IsChecked="{Binding IncludeReferenceData}" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,0"
                                   Text="Lookup/static tables are exported as deterministic INSERT scripts under data/ and change-tracked like any object. Tables over the row cap are reported, never truncated." />

                        <StackPanel Visibility="{Binding IncludeReferenceData, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="BROWSE TABLES IN" Style="{StaticResource Caption}" />
                                    <ComboBox ItemsSource="{Binding Databases}" DisplayMemberPath="Name"
                                              SelectedValuePath="Name" SelectedValue="{Binding TableSourceDatabase}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="Load tables" Style="{StaticResource SecondaryButton}"
                                        VerticalAlignment="Bottom" Command="{Binding LoadTablesCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                            </Grid>

                            <TextBlock Text="REFERENCE TABLES" Style="{StaticResource Caption}" Margin="0,14,0,0" />
                            <Border Style="{StaticResource Panel}" MaxHeight="240" Margin="0,4,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ReferenceTables}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Display}" IsChecked="{Binding IsSelected}" Margin="0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Text="ROW CAP PER TABLE" Style="{StaticResource Caption}" Margin="0,14,0,0" />
                            <TextBox Text="{Binding ReferenceDataMaxRows, UpdateSourceTrigger=PropertyChanged}"
                                     Width="140" HorizontalAlignment="Left" Margin="0,4,0,0"
                                     MaxLength="7" PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnPasteDigitsOnly" />
                        </StackPanel>

                        <Border Style="{StaticResource Divider}" Margin="0,20,0,16" />

                        <!-- Per-database generated files -->
                        <TextBlock Text="GENERATED FILES" Style="{StaticResource Caption}" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,2,0,10"
                                   Text="Written alongside the scripts and committed only when their content changes." />
                        <CheckBox Content="Object inventory (metadata/object-inventory.json)"
                                  IsChecked="{Binding IncludeObjectInventory}" />
                        <CheckBox Content="Database options script (metadata/database-options.sql)"
                                  IsChecked="{Binding IncludeDatabaseOptions}" Margin="0,8,0,0" />
                        <CheckBox Content="Consolidated permissions script (security/permissions/permissions.sql)"
                                  IsChecked="{Binding IncludePermissionsFile}" Margin="0,8,0,0" />
                        <CheckBox Content="Schema documentation (docs/README.md — object index + data dictionary)"
                                  IsChecked="{Binding IncludeDocumentation}" Margin="0,8,0,0" />
                        <CheckBox Content="Security review (security/security-review.md — versioned findings)"
                                  IsChecked="{Binding IncludeSecurityReview}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Step 3 · Destination -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Destination" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="How and where the scripted objects are delivered." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <TextBlock Text="COMMIT MODE" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding CommitModes}" SelectedItem="{Binding SelectedCommitMode}" Margin="0,4,0,4">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{Binding CommitModeDescription}" Style="{StaticResource Caption}"
                                   TextWrapping="Wrap" Margin="0,0,0,16" />

                        <!-- Git modes (Direct / Pull request / Local commit): repository + branch -->
                        <StackPanel Visibility="{Binding IsGitMode, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="GITHUB REPOSITORY" Style="{StaticResource Caption}" />
                            <ComboBox ItemsSource="{Binding Repositories}" SelectedItem="{Binding SelectedRepository}"
                                      DisplayMemberPath="FullName" Margin="0,4,0,16" />

                            <TextBlock Text="BRANCH" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding Branch, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsPullRequest, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="REVIEWERS (OPTIONAL, COMMA-SEPARATED GITHUB USERNAMES)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding Reviewers, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                        </StackPanel>

                        <!-- Export Only: a folder or .zip destination, no GitHub -->
                        <StackPanel Visibility="{Binding IsExportOnly, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="EXPORT DESTINATION (FOLDER OR .ZIP; A UNC PATH IS A NETWORK SHARE)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding ExportPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                        </StackPanel>

                        <TextBlock Text="DESTINATION FOLDER" Style="{StaticResource Caption}" />
                        <TextBlock Text="Blank = environments/&lt;server&gt;/&lt;database&gt;" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                        <TextBox Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,4" />
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Files will be written to:" /><Run Text=" " /><Run Text="{Binding FolderPreview, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Text="{Binding DestinationCollisionWarning}" Style="{StaticResource Caption}"
                                   Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" Margin="0,0,0,4"
                                   Visibility="{Binding DestinationCollisionWarning, Converter={StaticResource NullToVisibility}}" />

                        <TextBlock Text="LOCAL EXPORT PATH (OPTIONAL)" Style="{StaticResource Caption}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding LocalExportPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Step 4 · Schedule -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep4, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Schedule" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="How often this job runs." Style="{StaticResource Caption}" Margin="0,0,0,18" />

                        <!-- The background service isn't currently able to execute schedules; only shown
                             when the chosen cadence actually needs the service (non-manual or startup). -->
                        <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="{StaticResource RadiusControl}"
                                Padding="12,10" Margin="0,0,0,16"
                                Visibility="{Binding ShowScheduleServiceNotice, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconWarning}"
                                           Foreground="{StaticResource WarningBrush}" FontSize="14" VerticalAlignment="Top" Margin="0,1,8,0" />
                                <TextBlock Text="{Binding ScheduleServiceNotice}" Style="{StaticResource Caption}" TextWrapping="Wrap" MaxWidth="560" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="CADENCE" Style="{StaticResource Caption}" />
                        <ComboBox ItemsSource="{Binding ScheduleKinds}" SelectedItem="{Binding SelectedScheduleKind}" Margin="0,4,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Visibility="{Binding ShowHourly, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="EVERY N HOURS" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding IntervalHours, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16"
                                     MaxLength="3" PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnPasteDigitsOnly" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowDayTime, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="TIME OF DAY (HH:MM)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding TimeOfDay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16"
                                     MaxLength="5" PreviewTextInput="OnTimeInput" DataObject.Pasting="OnPasteTime" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowWeekday, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="DAY OF WEEK" Style="{StaticResource Caption}" />
                            <ComboBox ItemsSource="{Binding DaysOfWeek}" SelectedItem="{Binding SelectedDayOfWeek}" Margin="0,4,0,16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowCron, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="CRON EXPRESSION (QUARTZ 7-FIELD)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding CronExpression, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                        </StackPanel>

                        <TextBlock Text="{Binding NextRunPreview}" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,4"
                                   Visibility="{Binding NextRunPreview, Converter={StaticResource NullToVisibility}}" />
                        <TextBlock Text="If a scheduled run is still in progress when the next one is due, the new run is skipped."
                                   Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,4"
                                   Visibility="{Binding ShowOverlapNote, Converter={StaticResource BoolToVisibility}}" />

                        <Border Style="{StaticResource Divider}" />
                        <CheckBox Content="Also run once on app/service startup" IsChecked="{Binding RunOnStartup}" Margin="0,2,0,8" />
                        <CheckBox Content="Commit only when changes are detected" IsChecked="{Binding RunOnlyIfChanges}" Margin="0,0,0,2" />

                        <Border Style="{StaticResource Divider}" />
                        <CheckBox Content="Only run during a maintenance window" IsChecked="{Binding MaintenanceWindowEnabled}" Margin="0,2,0,8" />
                        <StackPanel Visibility="{Binding MaintenanceWindowEnabled, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="WINDOW START (HH:MM)" Style="{StaticResource Caption}" />
                                    <TextBox Text="{Binding WindowStart, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"
                                             MaxLength="5" PreviewTextInput="OnTimeInput" DataObject.Pasting="OnPasteTime" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="WINDOW END (HH:MM)" Style="{StaticResource Caption}" />
                                    <TextBox Text="{Binding WindowEnd, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"
                                             MaxLength="5" PreviewTextInput="OnTimeInput" DataObject.Pasting="OnPasteTime" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="DAYS" Style="{StaticResource Caption}" />
                            <ComboBox ItemsSource="{Binding DayScopes}" SelectedItem="{Binding SelectedDayScope}" Margin="0,4,0,4">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Scheduled runs outside the window are skipped; manual 'Run Now' always runs."
                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,4" />
                        </StackPanel>

                        <Border Style="{StaticResource Divider}" />
                        <CheckBox Content="Show advanced settings" IsChecked="{Binding ShowAdvanced}" Margin="0,2,0,8" />
                        <StackPanel Visibility="{Binding ShowAdvanced, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="MAX PARALLEL WORKERS (0 = AUTO)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding MaxParallelWorkers, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"
                                     MaxLength="3" PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnPasteDigitsOnly" />
                            <TextBlock Text="QUERY TIMEOUT (SECONDS)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding QueryTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"
                                     MaxLength="5" PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnPasteDigitsOnly" />
                            <TextBlock Text="LOCK TIMEOUT (SECONDS, 0 = SERVER DEFAULT)" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding LockTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"
                                     MaxLength="5" PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnPasteDigitsOnly" />
                            <CheckBox Content="Incremental scripting (recommended for very large databases)"
                                      IsChecked="{Binding IncrementalScripting}" Margin="0,0,0,6" />
                            <TextBlock Text="Skips objects unchanged since the last run using SQL Server's modify_date. Permission- or extended-property-only changes don't update modify_date — turn this off and run once to capture those."
                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,4" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Step 5 · Review -->
                <Border Style="{StaticResource Card}" Visibility="{Binding IsStep5, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Review" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                        <TextBlock Text="Confirm the configuration before saving." Style="{StaticResource Caption}" Margin="0,0,0,16" />

                        <Border Style="{StaticResource Panel}" Padding="18,14">
                            <ItemsControl ItemsSource="{Binding ReviewItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource Caption}" VerticalAlignment="Top" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Optional preflight: advisory checks that never block Save -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Run preflight checks" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RunPreflightCommand}"
                                    ToolTip="Test the SQL connection, repository access, branch, credentials, and destination"
                                    AutomationProperties.Name="Run preflight checks"
                                    IsEnabled="{Binding IsPreflightRunning, Converter={StaticResource InverseBool}}" />
                            <TextBlock Text="Checking…" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding IsPreflightRunning, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                        <TextBlock Text="Optional — verifies the connection, repository, branch, credentials, and folder. Results never block saving."
                                   Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0" />

                        <ItemsControl ItemsSource="{Binding PreflightResults}" Margin="0,10,0,0"
                                      Visibility="{Binding PreflightResults.Count, Converter={StaticResource CountToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="Auto" MinWidth="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontWeight="Bold" VerticalAlignment="Top">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#x2715;" />
                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pass">
                                                            <Setter Property="Text" Value="&#x2713;" />
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                            <Setter Property="Text" Value="!" />
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource BodyStrong}" Margin="0,0,12,0" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Style="{StaticResource Muted}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,18,0,0">
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" VerticalAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="340" HorizontalAlignment="Left" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource SubtleButton}" Click="OnCancel" Margin="0,0,8,0" />
                <Button Content="Back" Style="{StaticResource SecondaryButton}" Command="{Binding BackCommand}"
                        Margin="0,0,8,0" Visibility="{Binding ShowBack, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Next" Style="{StaticResource PrimaryButton}" Command="{Binding NextCommand}"
                        Visibility="{Binding ShowNext, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Save Job" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
