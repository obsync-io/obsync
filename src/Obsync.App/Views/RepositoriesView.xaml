<UserControl x:Class="Obsync.App.Views.RepositoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Repositories" Style="{StaticResource PageTitle}" />
                <TextBlock Text="The GitHub repositories your sync jobs commit to" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="OnAddRepository">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconAdd}" Foreground="White" FontSize="14" />
                    <TextBlock Text="Add repository" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Style="{StaticResource Muted}" Margin="0,14,0,0" TextWrapping="Wrap"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />

        <!-- Repositories table -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Repositories}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding Repositories.Count, Converter={StaticResource CountToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="1.3*" MinWidth="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrong}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Repository" Width="2*" MinWidth="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRepositories}" FontSize="13" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding FullName}" Style="{StaticResource Body}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding FullName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Default branch" Width="1*" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconBranch}" FontSize="13" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding DefaultBranch}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="128">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButton}" ToolTip="Check token" AutomationProperties.Name="Check token"
                                                IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBool}}"
                                                Command="{Binding DataContext.CheckTokenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRefresh}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Edit" AutomationProperties.Name="Edit" Margin="2,0,0,0" Click="OnEditRepository">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconEdit}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Delete" AutomationProperties.Name="Delete" Margin="2,0,0,0" Click="OnDeleteRepository">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconDelete}" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380" Margin="24">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Repositories.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRepositories}" FontSize="24" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="No repositories yet" Style="{StaticResource SectionTitle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="Add a GitHub repository for your sync jobs to commit database scripts to." Style="{StaticResource Muted}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                    <Button Content="Add repository" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center" Margin="0,18,0,0" Click="OnAddRepository" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
