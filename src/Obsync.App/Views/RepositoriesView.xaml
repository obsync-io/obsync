<UserControl x:Class="Obsync.App.Views.RepositoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Repositories" Style="{StaticResource PageTitle}" />
            <TextBlock Text="GitHub repositories your jobs commit to" Style="{StaticResource Muted}" Margin="0,4,0,18" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0">
                <DataGrid ItemsSource="{Binding Repositories}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0"
                          Background="Transparent" RowBackground="Transparent" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Repository" Binding="{Binding FullName}" Width="*" />
                        <DataGridTextColumn Header="Branch" Binding="{Binding DefaultBranch}" Width="Auto" />
                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Delete" Style="{StaticResource SecondaryButton}" Margin="4,3"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Add a repository" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                    <TextBlock Text="Name" Style="{StaticResource Muted}" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />
                    <TextBlock Text="Owner" Style="{StaticResource Muted}" />
                    <TextBox Text="{Binding Owner, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />
                    <TextBlock Text="Repository name" Style="{StaticResource Muted}" />
                    <TextBox Text="{Binding RepositoryName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />
                    <TextBlock Text="Default branch" Style="{StaticResource Muted}" />
                    <TextBox Text="{Binding DefaultBranch, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />
                    <TextBlock Text="Fine-grained access token" Style="{StaticResource Muted}" />
                    <PasswordBox x:Name="TokenBox" PasswordChanged="OnTokenChanged" Padding="8,6" Margin="0,2,0,14" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Validate" Style="{StaticResource SecondaryButton}" Command="{Binding ValidateCommand}" Margin="0,0,8,0" />
                        <Button Content="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding ValidationResult}" Style="{StaticResource Muted}" Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
