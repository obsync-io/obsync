<Window x:Class="Obsync.App.Views.AppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource AppFontFamily}" Foreground="{StaticResource TextPrimaryBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Width="424" Margin="24">
        <!-- Shadow layer (no text, so it never blurs the dialog content). -->
        <Border CornerRadius="14" Background="{StaticResource CardBrush}">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" BlurRadius="30" ShadowDepth="5" Direction="270" Opacity="0.20" />
            </Border.Effect>
        </Border>

        <!-- Content -->
        <Border CornerRadius="14" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Padding="24">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="IconChip" Width="42" Height="42" CornerRadius="12" VerticalAlignment="Top"
                            Background="{StaticResource WarningSoftBrush}">
                        <TextBlock x:Name="IconGlyph" Style="{StaticResource Icon}" Text="{StaticResource IconWarning}"
                                   FontSize="20" Foreground="{StaticResource WarningBrush}" />
                    </Border>
                    <TextBlock x:Name="TitleText" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"
                               Margin="14,0,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock x:Name="MessageText" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,14,0,0" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource SubtleButton}"
                            IsCancel="True" Click="OnCancel" Margin="0,0,8,0" />
                    <Button x:Name="ConfirmButton" Content="OK" Style="{StaticResource PrimaryButton}"
                            IsDefault="True" Click="OnConfirm" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
