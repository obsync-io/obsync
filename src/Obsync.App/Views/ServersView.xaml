<UserControl x:Class="Obsync.App.Views.ServersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Servers" Style="{StaticResource PageTitle}" />
                <TextBlock Text="The SQL Server instances Obsync connects to" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="OnAddServer">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconAdd}" Foreground="White" FontSize="14" />
                    <TextBlock Text="Add server" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Style="{StaticResource Muted}" Margin="0,14,0,0" TextWrapping="Wrap"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />

        <!-- Servers table -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Servers}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding Servers.Count, Converter={StaticResource CountToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="1.2*" MinWidth="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrong}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Server / instance" Width="1.8*" MinWidth="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ServerName}" Style="{StaticResource Body}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="24" Height="24" Margin="4,0,0,0"
                                                VerticalAlignment="Center" ToolTip="Copy server name" AutomationProperties.Name="Copy server name"
                                                Click="OnCopyServerName">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconCopy}" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Authentication" Width="1*" MinWidth="108">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AuthenticationMode, Converter={StaticResource EnumDisplay}}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="SQL Server" Width="1.6*" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- Edition · version, captured at test time; empty until the first successful test. -->
                                    <TextBlock Text="{Binding ServerProductDisplay}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding ServerProductDisplay}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ServerProductDisplay}" Value="">
                                                        <Setter Property="ToolTipService.IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Last checked" Width="1.1*" MinWidth="95">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                                <Setter Property="Text" Value="{Binding LastTestedAt, Converter={StaticResource LocalDateTime}}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LastTestedAt}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="—" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Status" Width="1.2*" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- Clean single badge; the tested time + server detail live in a hover tooltip. -->
                                    <ContentControl Content="{Binding LastTestStatus}" ContentTemplate="{StaticResource ConnectionStatusBadgeTemplate}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="ToolTipService.InitialShowDelay" Value="150" />
                                                <Setter Property="ToolTipService.ShowDuration" Value="20000" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LastTestedAt}" Value="{x:Null}">
                                                        <Setter Property="ToolTipService.IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                        <ContentControl.ToolTip>
                                            <ToolTip>
                                                <StackPanel MaxWidth="360">
                                                    <TextBlock Text="{Binding LastTestDetail}" TextWrapping="Wrap" FontSize="12"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               Visibility="{Binding LastTestDetail, Converter={StaticResource NullToVisibility}}" />
                                                    <TextBlock Text="{Binding LastTestedAt, StringFormat='Last tested {0:g}'}" FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </ToolTip>
                                        </ContentControl.ToolTip>
                                    </ContentControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="128">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButton}" ToolTip="Test connection" AutomationProperties.Name="Test connection"
                                                IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBool}}"
                                                Command="{Binding DataContext.TestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRefresh}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Edit" AutomationProperties.Name="Edit" Margin="2,0,0,0" Click="OnEditServer">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconEdit}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Delete" AutomationProperties.Name="Delete" Margin="2,0,0,0" Click="OnDeleteServer">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconDelete}" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380" Margin="24">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Servers.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconConnections}" FontSize="24" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="No servers yet" Style="{StaticResource SectionTitle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="Add your first SQL Server to connect Obsync to your databases." Style="{StaticResource Muted}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                    <Button Content="Add server" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center" Margin="0,18,0,0" Click="OnAddServer" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
