<UserControl x:Class="Obsync.App.Views.JobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Sync Jobs" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Create, view, and run sync jobs" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ImportJobCommand}"
                        Margin="0,0,10,0" ToolTip="Import a job configuration exported from another machine">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconImport}" FontSize="14" />
                        <TextBlock Text="Import" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" Click="OnCreateJob">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconAdd}" Foreground="White" FontSize="14" />
                        <TextBlock Text="Create Sync Job" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Style="{StaticResource Muted}" Margin="0,14,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />

        <!-- Jobs table -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Jobs}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding Jobs.Count, Converter={StaticResource CountToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Job Name" Width="1.7*" MinWidth="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrong}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Source" Width="1.7*" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SourceDisplay}" Style="{StaticResource Body}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Destination" Width="1.9*" MinWidth="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DestinationDisplay}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Tags" Width="1.3*" MinWidth="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding TagChips}" Style="{StaticResource TagChipsList}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding DisplayStatus}" ContentTemplate="{StaticResource StatusBadgeTemplate}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Last Run" Width="1.3*" MinWidth="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RunSummary.LastRunAt, Converter={StaticResource LocalDateTime}}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Changes" Width="0.8*" MinWidth="64">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RunSummary.LastChangeCount}" Style="{StaticResource Body}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Next Run" Width="1.3*" MinWidth="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RunSummary.NextRunAt, Converter={StaticResource LocalDateTime}}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="156">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButton}" ToolTip="Open" AutomationProperties.Name="Open" Click="OnOpenJob">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconOpen}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Run Now" AutomationProperties.Name="Run Now" Margin="2,0,0,0"
                                                Command="{Binding DataContext.RunNowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRun}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Edit" AutomationProperties.Name="Edit" Margin="2,0,0,0" Click="OnEditJob">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconEdit}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Delete" AutomationProperties.Name="Delete" Margin="2,0,0,0" Click="OnDeleteJob">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconDelete}" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" Margin="0,48,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Jobs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconJobs}" FontSize="24" Foreground="{StaticResource TextMutedBrush}" />
                    </Border>
                    <TextBlock Text="No sync jobs yet" Style="{StaticResource SectionTitle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="Create your first sync job to start versioning SQL Server objects to GitHub."
                               Style="{StaticResource Muted}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0" />
                    <Button Content="Create Sync Job" Style="{StaticResource PrimaryButton}" Click="OnCreateJob" HorizontalAlignment="Center" Margin="0,18,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
