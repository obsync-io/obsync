<UserControl x:Class="Obsync.App.Views.JobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Row overflow ("⋯") menu, styled like the ComboBox popup: rounded card, hairline border. -->
        <Style x:Key="RowMenu" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="0,4" MinWidth="200" SnapsToDevicePixels="True">
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Plain (leaf) menu item for the overflow menu — no submenu/gesture chrome needed. -->
        <Style x:Key="RowMenuItem" TargetType="MenuItem">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="4,1" Padding="10,7">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PanelBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Sync Jobs" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Create, view, and run sync jobs" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ImportJobCommand}"
                        Margin="0,0,10,0" ToolTip="Import a job configuration exported from another machine">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconImport}" FontSize="14" />
                        <TextBlock Text="Import" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" Click="OnCreateJob">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconAdd}" Foreground="White" FontSize="14" />
                        <TextBlock Text="Create Sync Job" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Scheduler health: schedules exist that the background service can't execute -->
        <Border Grid.Row="1" Background="{StaticResource WarningSoftBrush}" CornerRadius="{StaticResource RadiusControl}"
                Padding="14,10" Margin="0,14,0,0"
                Visibility="{Binding SchedulerWarning, Converter={StaticResource NullToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconWarning}"
                           Foreground="{StaticResource WarningBrush}" FontSize="15" VerticalAlignment="Top" Margin="0,1,10,0" />
                <TextBlock Text="{Binding SchedulerWarning}" Style="{StaticResource Body}" TextWrapping="Wrap" MaxWidth="900" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Style="{StaticResource Muted}" Margin="0,14,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />

        <!-- Jobs table -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Jobs}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding Jobs.Count, Converter={StaticResource CountToVisibility}}">
                    <!-- Column budget: fixed widths fit their widest content (Actions = its five
                         buttons, Changes = its header, Status = the "No changes" badge) and the
                         MinWidths of the flexible columns fit their headers — so nothing clips or
                         truncates down to a 960-wide content area (verified by TableLayoutTests). -->
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Job Name" Width="1.6*" MinWidth="86">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrong}" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Source" Width="1.6*" MinWidth="66">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SourceDisplay}" Style="{StaticResource Body}" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Destination" Width="1.8*" MinWidth="94">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DestinationDisplay}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Tags" Width="1.1*" MinWidth="54">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding TagChips}" Style="{StaticResource TagChipsList}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="122">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource JobStatusBadgeTemplate}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Last Run" Width="1.2*" MinWidth="78">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RunSummary.LastRunAt, Converter={StaticResource LocalDateTime}}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Changes" Width="78">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RunSummary.LastChangeCount}" Style="{StaticResource Body}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Next Run" Width="1.2*" MinWidth="92">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NextRunCellTemplate}" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="194">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButton}" ToolTip="Open" AutomationProperties.Name="Open" Click="OnOpenJob">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconOpen}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Run Now" AutomationProperties.Name="Run Now" Margin="2,0,0,0"
                                                Command="{Binding DataContext.RunNowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRun}" />
                                        </Button>
                                        <!-- Pause/resume toggle: glyph, tooltip, and automation name all
                                             follow the job's Enabled state. -->
                                        <Button Margin="2,0,0,0"
                                                Command="{Binding DataContext.TogglePauseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                    <Setter Property="ToolTip" Value="Pause schedule" />
                                                    <Setter Property="AutomationProperties.Name" Value="Pause schedule" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                            <Setter Property="ToolTip" Value="Resume schedule" />
                                                            <Setter Property="AutomationProperties.Name" Value="Resume schedule" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Icon}">
                                                        <Setter Property="Text" Value="{StaticResource IconPause}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                <Setter Property="Text" Value="{StaticResource IconRun}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Edit" AutomationProperties.Name="Edit" Margin="2,0,0,0" Click="OnEditJob">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconEdit}" />
                                        </Button>
                                        <!-- Overflow menu for the rarer actions so the row stays uncluttered. -->
                                        <Button Style="{StaticResource IconButton}" ToolTip="More actions" AutomationProperties.Name="More actions"
                                                Margin="2,0,0,0" Click="OnRowMenu">
                                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconMore}" />
                                            <Button.ContextMenu>
                                                <ContextMenu Style="{StaticResource RowMenu}">
                                                    <MenuItem Style="{StaticResource RowMenuItem}" Header="Duplicate"
                                                              AutomationProperties.Name="Duplicate" Click="OnDuplicateJob" />
                                                    <MenuItem Style="{StaticResource RowMenuItem}" Header="Export configuration…"
                                                              AutomationProperties.Name="Export configuration" Click="OnExportJob" />
                                                    <MenuItem Style="{StaticResource RowMenuItem}" Header="Delete"
                                                              Foreground="{StaticResource ErrorBrush}"
                                                              AutomationProperties.Name="Delete" Click="OnDeleteJob" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400" Margin="0,48,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Jobs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconJobs}" FontSize="24" Foreground="{StaticResource TextMutedBrush}" />
                    </Border>
                    <TextBlock Text="No sync jobs yet" Style="{StaticResource SectionTitle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="Create your first sync job to start versioning SQL Server objects to GitHub."
                               Style="{StaticResource Muted}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0" />
                    <Button Content="Create Sync Job" Style="{StaticResource PrimaryButton}" Click="OnCreateJob" HorizontalAlignment="Center" Margin="0,18,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
