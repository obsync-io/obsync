<UserControl x:Class="Obsync.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}" />
            <TextBlock Text="High-level health and recent activity" Style="{StaticResource Muted}" Margin="0,4,0,20" />

            <!-- Metric cards -->
            <UniformGrid Rows="1" Columns="5">
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Total Sync Jobs" Style="{StaticResource Muted}" FontSize="12" />
                        <TextBlock Text="{Binding TotalJobs}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Successful Last Runs" Style="{StaticResource Muted}" FontSize="12" />
                        <TextBlock Text="{Binding SuccessfulLastRuns}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Failed Jobs" Style="{StaticResource Muted}" FontSize="12" />
                        <TextBlock Text="{Binding FailedJobs}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Objects Tracked" Style="{StaticResource Muted}" FontSize="12" />
                        <TextBlock Text="{Binding ObjectsTracked}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Latest GitHub Commit" Style="{StaticResource Muted}" FontSize="12" />
                        <TextBlock Text="{Binding LatestCommit}" Style="{StaticResource MetricValue}" FontSize="22" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Jobs table -->
            <Border Style="{StaticResource Card}" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="Sync Jobs" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                    <DataGrid ItemsSource="{Binding Jobs}" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0"
                              Background="Transparent" RowBackground="Transparent" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Job Name" Binding="{Binding Name}" Width="2*" />
                            <DataGridTextColumn Header="Databases" Binding="{Binding DatabasesDisplay}" Width="2*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding RunSummary.LastStatus}" Width="*" />
                            <DataGridTextColumn Header="Last Run" Binding="{Binding RunSummary.LastRunAt, StringFormat=g}" Width="1.5*" />
                            <DataGridTextColumn Header="Changes" Binding="{Binding RunSummary.LastChangeCount}" Width="*" />
                            <DataGridTextColumn Header="Next Run" Binding="{Binding RunSummary.NextRunAt, StringFormat=g}" Width="1.5*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
