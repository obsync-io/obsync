<UserControl x:Class="Obsync.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}" />
            <TextBlock Text="High-level health and recent activity" Style="{StaticResource Muted}" Margin="0,4,0,20" />

            <!-- Metric cards: a WrapPanel of fixed-width cards so they reflow onto a second row on
                 narrow windows instead of squeezing. Inside each card a DockPanel keeps the caption
                 from overlapping the icon chip (it trims with an ellipsis if the card is narrow). -->
            <WrapPanel>
                <!-- Total Sync Jobs -->
                <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right" Width="36" Height="36" VerticalAlignment="Top"
                                    CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource AccentSoftBrush}">
                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconJobs}"
                                           Foreground="{StaticResource AccentBrush}" FontSize="18" />
                            </Border>
                            <TextBlock Text="Total Sync Jobs" Style="{StaticResource Caption}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding TotalJobs}" Style="{StaticResource MetricValue}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Successful Last Runs -->
                <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right" Width="36" Height="36" VerticalAlignment="Top"
                                    CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource SuccessSoftBrush}">
                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconCheck}"
                                           Foreground="{StaticResource SuccessBrush}" FontSize="18" />
                            </Border>
                            <TextBlock Text="Successful Last Runs" Style="{StaticResource Caption}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding SuccessfulLastRuns}" Style="{StaticResource MetricValue}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Failed Jobs -->
                <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right" Width="36" Height="36" VerticalAlignment="Top"
                                    CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource ErrorSoftBrush}">
                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconError}"
                                           Foreground="{StaticResource ErrorBrush}" FontSize="18" />
                            </Border>
                            <TextBlock Text="Failed Jobs" Style="{StaticResource Caption}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding FailedJobs}" Style="{StaticResource MetricValue}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Objects Tracked -->
                <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right" Width="36" Height="36" VerticalAlignment="Top"
                                    CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource NeutralSoftBrush}">
                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconDatabase}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="18" />
                            </Border>
                            <TextBlock Text="Objects Tracked" Style="{StaticResource Caption}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                        </DockPanel>
                        <TextBlock Text="{Binding ObjectsTracked}" Style="{StaticResource MetricValue}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Latest Commit -->
                <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right" Width="36" Height="36" VerticalAlignment="Top"
                                    CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource AccentSoftBrush}">
                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconBranch}"
                                           Foreground="{StaticResource AccentBrush}" FontSize="18" />
                            </Border>
                            <TextBlock Text="Latest Commit" Style="{StaticResource Caption}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                        </DockPanel>
                        <!-- No open-commit command on the VM, so the short SHA is rendered as static BodyStrong text. -->
                        <TextBlock Text="{Binding LatestCommit}" Style="{StaticResource BodyStrong}"
                                   FontSize="20" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Getting started (shown only when there are no jobs yet) -->
            <Border Margin="0,20,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Jobs.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Set up your first sync" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Three quick steps to start versioning SQL Server objects to GitHub."
                               Style="{StaticResource Muted}" Margin="0,4,0,0" />

                    <UniformGrid Rows="1" Columns="3" Margin="0,20,0,0">
                        <!-- Step 1 -->
                        <Border Style="{StaticResource Panel}" Margin="0,0,12,0" Padding="18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14" Background="{StaticResource AccentSoftBrush}">
                                        <TextBlock Text="1" Style="{StaticResource BodyStrong}" Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconConnections}" FontSize="18"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="Add a SQL Server connection" Style="{StaticResource BodyStrong}" Margin="0,14,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="Point Obsync at the database you want to track." Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                <Button Content="Add server" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,14,0,0"
                                        Tag="Servers" Click="OnGoToSection" />
                            </StackPanel>
                        </Border>

                        <!-- Step 2 -->
                        <Border Style="{StaticResource Panel}" Margin="0,0,12,0" Padding="18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14" Background="{StaticResource AccentSoftBrush}">
                                        <TextBlock Text="2" Style="{StaticResource BodyStrong}" Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRepositories}" FontSize="18"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="Add a GitHub repository" Style="{StaticResource BodyStrong}" Margin="0,14,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="Choose where versioned objects are committed." Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                <Button Content="Add repository" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,14,0,0"
                                        Tag="Repositories" Click="OnGoToSection" />
                            </StackPanel>
                        </Border>

                        <!-- Step 3 -->
                        <Border Style="{StaticResource Panel}" Padding="18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="14" Background="{StaticResource AccentSoftBrush}">
                                        <TextBlock Text="3" Style="{StaticResource BodyStrong}" Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconJobs}" FontSize="18"
                                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="Create a sync job" Style="{StaticResource BodyStrong}" Margin="0,14,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="Connect a source and destination, then run it." Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                <Button Content="Create Sync Job" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,14,0,0"
                                        Click="OnCreateJob" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Jobs table (shown once at least one job exists) -->
            <Border Margin="0,20,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Jobs.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Sync Jobs" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                    <!-- Run progress/status is shown in the job's Overview tab, not as a floating line here. -->
                    <!-- Bounded height so DataGrid row virtualization works (the grid scrolls
                         internally rather than realizing every row inside the page ScrollViewer). -->
                    <DataGrid ItemsSource="{Binding Jobs}" Margin="0,8,0,0" MaxHeight="520"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Job Name" Width="1.8*" MinWidth="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrong}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Source" Width="1.8*" MinWidth="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SourceDisplay}" Style="{StaticResource Body}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Destination" Width="1.8*" MinWidth="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DestinationDisplay}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Tags" Width="1.3*" MinWidth="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding TagChips}" Style="{StaticResource TagChipsList}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding DisplayStatus}" ContentTemplate="{StaticResource StatusBadgeTemplate}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Last Run" Width="1.3*" MinWidth="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunSummary.LastRunAt, Converter={StaticResource LocalDateTime}}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Changes" Width="0.8*" MinWidth="64">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunSummary.LastChangeCount}" Style="{StaticResource Body}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Next Run" Width="1.3*" MinWidth="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunSummary.NextRunAt, Converter={StaticResource LocalDateTime}}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Actions" Width="84">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconButton}" ToolTip="Open" AutomationProperties.Name="Open"
                                                    Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconOpen}" />
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" ToolTip="Run Now" AutomationProperties.Name="Run Now" Margin="2,0,0,0"
                                                    Command="{Binding DataContext.RunNowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRun}" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
