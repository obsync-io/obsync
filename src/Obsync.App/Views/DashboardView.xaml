<UserControl x:Class="Obsync.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}" />
            <TextBlock Text="High-level health and recent activity" Style="{StaticResource Muted}" Margin="0,4,0,20" />

            <!-- Metric cards -->
            <UniformGrid Rows="1" Columns="5">
                <!-- Total Sync Jobs -->
                <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Total Sync Jobs" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding TotalJobs}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="38" Height="38" VerticalAlignment="Top"
                                CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource AccentSoftBrush}">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconJobs}"
                                       Foreground="{StaticResource AccentBrush}" FontSize="18" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Successful Last Runs -->
                <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Successful Last Runs" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding SuccessfulLastRuns}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="38" Height="38" VerticalAlignment="Top"
                                CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource SuccessSoftBrush}">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconCheck}"
                                       Foreground="{StaticResource SuccessBrush}" FontSize="18" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Failed Jobs -->
                <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Failed Jobs" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding FailedJobs}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="38" Height="38" VerticalAlignment="Top"
                                CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource ErrorSoftBrush}">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconError}"
                                       Foreground="{StaticResource ErrorBrush}" FontSize="18" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Objects Tracked -->
                <Border Style="{StaticResource Card}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Objects Tracked" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding ObjectsTracked}" Style="{StaticResource MetricValue}" Margin="0,6,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="38" Height="38" VerticalAlignment="Top"
                                CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource NeutralSoftBrush}">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconDatabase}"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="18" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Latest GitHub Commit -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Latest GitHub Commit" Style="{StaticResource Caption}" />
                            <!-- No open-commit command on the VM, so the short SHA is rendered as static BodyStrong text. -->
                            <TextBlock Text="{Binding LatestCommit}" Style="{StaticResource BodyStrong}"
                                       FontSize="20" Margin="0,8,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Width="38" Height="38" VerticalAlignment="Top"
                                CornerRadius="{StaticResource RadiusControl}" Background="{StaticResource AccentSoftBrush}">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconBranch}"
                                       Foreground="{StaticResource AccentBrush}" FontSize="18" />
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Jobs table -->
            <Border Style="{StaticResource Card}" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="Sync Jobs" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" Margin="0,0,0,8"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />
                    <DataGrid ItemsSource="{Binding Jobs}" Margin="0,8,0,0">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Job Name" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrong}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Source" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SourceDisplay}" Style="{StaticResource Body}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Destination" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DestinationDisplay}" Style="{StaticResource Muted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Status" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding RunSummary.LastStatus}" ContentTemplate="{StaticResource StatusBadgeTemplate}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Last Run" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunSummary.LastRunAt, StringFormat=g}" Style="{StaticResource Muted}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Changes" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunSummary.LastChangeCount}" Style="{StaticResource Body}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Next Run" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunSummary.NextRunAt, StringFormat=g}" Style="{StaticResource Muted}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Actions" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource IconButton}" ToolTip="Open"
                                                    Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconOpen}" />
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" ToolTip="Run Now" Margin="2,0,0,0"
                                                    Command="{Binding DataContext.RunNowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconRun}" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
