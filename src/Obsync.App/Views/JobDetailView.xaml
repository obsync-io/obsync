<UserControl x:Class="Obsync.App.Views.JobDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============================ Header band (no card) ============================ -->
        <StackPanel Grid.Row="0">

            <!-- Back -->
            <Button Style="{StaticResource SubtleButton}" HorizontalAlignment="Left"
                    Command="{Binding BackCommand}" Margin="-10,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconBack}"
                               FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Back to jobs" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Title row: name + status badge (left), Run Now + Edit (right) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding Job.Name}" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
                    <ContentControl Content="{Binding Status}" ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                    Margin="14,4,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding RunNowCommand}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconRun}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Run Now" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="OnEdit">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconEdit}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Edit" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Meta line: Last run · Next run · Last commit -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Style="{StaticResource Muted}" Text="Last run " VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding LastRunText}" VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Muted}" Text="  ·  Next run " VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding NextRunText}" VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Muted}" Text="  ·  Last commit " VerticalAlignment="Center"
                           Visibility="{Binding HasCommit, Converter={StaticResource BoolToVisibility}}" />
                <Button Style="{StaticResource LinkButton}" Content="{Binding LastCommitSha}"
                        Command="{Binding OpenCommitCommand}" VerticalAlignment="Center"
                        Visibility="{Binding HasCommit, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <!-- Live status message from the most recent action -->
            <TextBlock Style="{StaticResource Muted}" Text="{Binding StatusMessage}" Margin="0,8,0,0" TextWrapping="Wrap"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />
        </StackPanel>

        <!-- ================================== Tabs ================================== -->
        <TabControl Grid.Row="1" Margin="0,20,0,0" Background="Transparent" BorderThickness="0">

            <!-- Overview -->
            <TabItem Header="Overview">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0" VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection" Style="{StaticResource Caption}" Margin="0,8" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionName}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Source SQL Server" Style="{StaticResource Caption}" Margin="0,8" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ServerName}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Database" Style="{StaticResource Caption}" Margin="0,8" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DatabasesText}" Style="{StaticResource BodyStrong}" Margin="0,8" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="GitHub repository" Style="{StaticResource Caption}" Margin="0,8" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RepositoryFullName}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Branch" Style="{StaticResource Caption}" Margin="0,8" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Branch}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Folder path" Style="{StaticResource Caption}" Margin="0,8" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Folder}" Style="{StaticResource BodyStrong}" Margin="0,8" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Schedule" Style="{StaticResource Caption}" Margin="0,8" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ScheduleText}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Last result" Style="{StaticResource Caption}" Margin="0,8" />
                        <ContentControl Grid.Row="7" Grid.Column="1" Content="{Binding Status}"
                                        ContentTemplate="{StaticResource StatusBadgeTemplate}" Margin="0,8" HorizontalAlignment="Left" />
                    </Grid>
                </Border>
            </TabItem>

            <!-- Changes (latest run) -->
            <TabItem Header="Changes">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <DataGrid ItemsSource="{Binding Changes}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Change" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding ChangeType}" ContentTemplate="{StaticResource ChangeBadgeTemplate}"
                                                        Margin="0,4" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Object" Binding="{Binding QualifiedName}" Width="*" />
                            <DataGridTextColumn Header="Path" Binding="{Binding RelativePath}" Width="2*" />
                            <DataGridTemplateColumn Header="Actions" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource IconButton}" ToolTip="Open in GitHub"
                                                Command="{Binding DataContext.OpenChangeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconOpenExternal}"
                                                       FontSize="15" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- History -->
            <TabItem Header="History">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <DataGrid ItemsSource="{Binding Runs}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Run time" Binding="{Binding StartedAt, StringFormat=g}" Width="1.6*" />
                            <DataGridTextColumn Header="Duration" Binding="{Binding DurationMs, Converter={StaticResource MsToDuration}}" Width="*" />
                            <DataGridTextColumn Header="Objects scanned" Binding="{Binding ObjectsScanned}" Width="*" />
                            <DataGridTextColumn Header="Objects changed" Binding="{Binding ChangeCount}" Width="*" />
                            <DataGridTextColumn Header="Commit SHA" Binding="{Binding CommitSha}" Width="1.4*" />
                            <DataGridTemplateColumn Header="Status" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding Status}" ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                                        Margin="0,4" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Configuration -->
            <TabItem Header="Configuration">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0" VerticalAlignment="Top">
                    <StackPanel>
                        <Border Background="{StaticResource PanelBrush}" CornerRadius="{StaticResource RadiusControl}"
                                Padding="16,14" Margin="0,0,0,16">
                            <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap"
                                       Text="Edit this job's source connection, selected objects, destination repository, branch, folder, and schedule in the job wizard. Changes take effect on the next run." />
                        </Border>
                        <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Click="OnEdit">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconEdit}"
                                           FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Edit configuration" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Logs (latest run) -->
            <TabItem Header="Logs">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Top" Content="Show technical details" IsChecked="{Binding ShowTechnicalLogs}"
                                  Margin="0,0,0,14" />
                        <DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="Auto" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
