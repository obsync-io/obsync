<UserControl x:Class="Obsync.App.Views.JobDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- A full-width clickable row in the Dependencies tab's result lists. -->
        <Style x:Key="DependencyRow" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsEnabled" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter Property="Cursor" Value="Hand" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- One direction of the dependency results (Used by / Uses). -->
        <DataTemplate x:Key="DependencyListTemplate">
            <Button Style="{StaticResource DependencyRow}" IsEnabled="{Binding IsDrillable}"
                    ToolTip="Explore this object's dependencies"
                    Command="{Binding DataContext.Dependencies.DrillIntoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding QualifiedName}" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding QualifiedName}" />
                    <TextBlock Grid.Column="1" Text="{Binding TypeLabel}" Style="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                </Grid>
            </Button>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============================ Header band (no card) ============================ -->
        <StackPanel Grid.Row="0">

            <!-- Back -->
            <Button Style="{StaticResource SubtleButton}" HorizontalAlignment="Left"
                    Command="{Binding BackCommand}" Margin="-10,0,0,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconBack}"
                               FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Back to jobs" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Title row: name + status badge (left), Run Now + Edit (right) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding Job.Name}" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
                    <ContentControl Content="{Binding Status}" ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                    Margin="14,4,0,0" VerticalAlignment="Center" />
                    <ItemsControl ItemsSource="{Binding Job.TagChips}" Style="{StaticResource TagChipsList}"
                                  Margin="10,4,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding RunNowCommand}" Margin="0,0,10,0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconRun}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Run Now" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Command="{Binding ExportReportCommand}" Margin="0,0,10,0"
                            ToolTip="Export this run as HTML, CSV, or JSON">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconExport}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Export report" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="OnEdit">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconEdit}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Edit" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Meta line: Last run · Next run · Last commit -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Style="{StaticResource Muted}" Text="Last run " VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding LastRunText}" VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Muted}" Text="  ·  Next run " VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding NextRunText}" VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Muted}" Text="  ·  Last commit " VerticalAlignment="Center"
                           Visibility="{Binding HasCommit, Converter={StaticResource BoolToVisibility}}" />
                <!-- Link when a commit URL exists; otherwise the SHA as plain text so a run with a
                     CommitSha but no URL still surfaces the commit. -->
                <Button Style="{StaticResource LinkButton}" Content="{Binding LastCommitSha}"
                        Command="{Binding OpenCommitCommand}" VerticalAlignment="Center"
                        Visibility="{Binding HasCommitLink, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Style="{StaticResource Body}" Text="{Binding LastCommitSha}" VerticalAlignment="Center"
                           Visibility="{Binding ShowCommitShaOnly, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Style="{StaticResource Muted}" Text="  ·  " VerticalAlignment="Center"
                           Visibility="{Binding HasPullRequest, Converter={StaticResource BoolToVisibility}}" />
                <Button Style="{StaticResource LinkButton}" Content="{Binding PullRequestLabel}"
                        Command="{Binding OpenPullRequestCommand}" VerticalAlignment="Center"
                        Visibility="{Binding HasPullRequest, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <!-- Scheduler health: this job's schedule can't be executed by the background service -->
            <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="{StaticResource RadiusControl}"
                    Padding="14,10" Margin="0,12,0,0"
                    Visibility="{Binding SchedulerWarning, Converter={StaticResource NullToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconWarning}"
                               Foreground="{StaticResource WarningBrush}" FontSize="15" VerticalAlignment="Top" Margin="0,1,10,0" />
                    <TextBlock Text="{Binding SchedulerWarning}" Style="{StaticResource Body}" TextWrapping="Wrap" MaxWidth="900" />
                </StackPanel>
            </Border>

            <!-- Live status message from the most recent action -->
            <TextBlock Style="{StaticResource Muted}" Text="{Binding StatusMessage}" Margin="0,8,0,0" TextWrapping="Wrap"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />

            <!-- Result of the last "Export report" action -->
            <TextBlock Style="{StaticResource Muted}" Text="{Binding ReportMessage}" Margin="0,8,0,0" TextWrapping="Wrap"
                       Visibility="{Binding ReportMessage, Converter={StaticResource NullToVisibility}}" />
        </StackPanel>

        <!-- ================================== Tabs ================================== -->
        <TabControl Grid.Row="1" Margin="0,20,0,0" Background="Transparent" BorderThickness="0">

            <!-- Overview -->
            <TabItem Header="Overview">
                <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Run status: badge, live progress, error banner, and the latest run's counts.
                             This is the one place to watch a job as it scripts, commits, and pushes. -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Run status" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    <ContentControl Content="{Binding Status}" ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                                    Margin="12,2,0,0" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Live progress (only while a run is in flight) -->
                                <StackPanel Margin="0,16,0,0" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Body}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Cancel run"
                                                Command="{Binding CancelRunCommand}" Margin="12,0,0,0" VerticalAlignment="Center" />
                                    </Grid>
                                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,10,0,0"
                                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource PanelBrush}" BorderThickness="0" />
                                </StackPanel>

                                <!-- Error / warning banner: shows exactly why a run did not fully succeed -->
                                <Border Margin="0,16,0,0" CornerRadius="{StaticResource RadiusControl}" Padding="14,12"
                                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                    <Setter Property="Background" Value="{StaticResource ErrorSoftBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconWarning}"
                                                   FontSize="16" VerticalAlignment="Top" Margin="0,1,10,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding LastError}" Style="{StaticResource Body}" TextWrapping="Wrap" MaxWidth="760" />
                                    </StackPanel>
                                </Border>

                                <!-- Latest run counts -->
                                <UniformGrid Rows="1" Columns="5" Margin="0,18,0,0"
                                             Visibility="{Binding HasLatestRun, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LatestRun.ObjectsScanned}" Style="{StaticResource MetricValue}" FontSize="24" />
                                        <TextBlock Text="Scanned" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding LatestRun.ObjectsAdded}" Style="{StaticResource MetricValue}" FontSize="24" />
                                        <TextBlock Text="Added" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding LatestRun.ObjectsModified}" Style="{StaticResource MetricValue}" FontSize="24" />
                                        <TextBlock Text="Modified" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding LatestRun.ObjectsDeleted}" Style="{StaticResource MetricValue}" FontSize="24" />
                                        <TextBlock Text="Deleted" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding LatestRun.ObjectsFailed}" Style="{StaticResource MetricValue}" FontSize="24" />
                                        <TextBlock Text="Skipped" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Configuration summary -->
                        <Border Style="{StaticResource Card}" Margin="0,16,0,0" VerticalAlignment="Top">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection" Style="{StaticResource Caption}" Margin="0,8" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConnectionName}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Source SQL Server" Style="{StaticResource Caption}" Margin="0,8" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ServerName}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Database" Style="{StaticResource Caption}" Margin="0,8" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DatabasesText}" Style="{StaticResource BodyStrong}" Margin="0,8" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="GitHub repository" Style="{StaticResource Caption}" Margin="0,8" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RepositoryFullName}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Branch" Style="{StaticResource Caption}" Margin="0,8" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Branch}" Style="{StaticResource BodyStrong}" Margin="0,8" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Folder path" Style="{StaticResource Caption}" Margin="0,8" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Folder}" Style="{StaticResource BodyStrong}" Margin="0,8" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Schedule" Style="{StaticResource Caption}" Margin="0,8" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ScheduleText}" Style="{StaticResource BodyStrong}" Margin="0,8" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Changes (latest run) -->
            <TabItem Header="Changes">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <DockPanel>
                        <!-- Shown when the run has more changes than the grid displays -->
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Text="{Binding ChangesNotice}"
                                   Margin="0,0,0,14" TextWrapping="Wrap"
                                   Visibility="{Binding ChangesNotice, Converter={StaticResource NullToVisibility}}" />
                        <DataGrid ItemsSource="{Binding Changes}" AutoGenerateColumns="False" IsReadOnly="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Change" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ContentControl Content="{Binding ChangeType}" ContentTemplate="{StaticResource ChangeBadgeTemplate}"
                                                            Margin="0,4" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Object" Binding="{Binding QualifiedName}" Width="*" MinWidth="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="ToolTip" Value="{Binding QualifiedName}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Path" Binding="{Binding RelativePath}" Width="2*" MinWidth="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="ToolTip" Value="{Binding RelativePath}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Actions" Width="88">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource IconButton}" ToolTip="View diff" AutomationProperties.Name="View diff"
                                                        Command="{Binding DataContext.ViewDiffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconDiff}"
                                                               FontSize="15" />
                                                </Button>
                                                <Button Style="{StaticResource IconButton}" ToolTip="Open in GitHub" AutomationProperties.Name="Open in GitHub"
                                                        Command="{Binding DataContext.OpenChangeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconOpenExternal}"
                                                               FontSize="15" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- Dependencies -->
            <TabItem Header="Dependencies" DataContext="{Binding Dependencies}">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Pickers -->
                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding Databases}" SelectedItem="{Binding SelectedDatabase}"
                                      ToolTip="Database (from the job's last sync)" Margin="0,0,10,0" />
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search the job's indexed objects by name or schema.name">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Style.Resources>
                                            <VisualBrush x:Key="SearchHint" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Search objects…" Foreground="{StaticResource TextMutedBrush}"
                                                               FontFamily="{StaticResource AppFontFamily}" FontSize="13" Margin="10,0,0,0" />
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background" Value="{StaticResource SearchHint}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Object picker (top matches from the local index) -->
                            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="4" Margin="0,0,14,0">
                                <ListBox ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedObject}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="6,3">
                                                <TextBlock TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding SchemaName, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}" /><Run Text="." Foreground="{StaticResource TextMutedBrush}" /><Run Text="{Binding ObjectName, Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding ObjectType, Converter={StaticResource EnumDisplay}}" Style="{StaticResource Caption}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- Results -->
                            <Grid Grid.Column="1">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasResults}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Pick an object to explore" Style="{StaticResource SectionTitle}"
                                               HorizontalAlignment="Center" TextAlignment="Center" />
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0"
                                               Text="See what depends on it before you change it — and what it uses. Read directly from the server's catalog, read-only." />
                                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" TextWrapping="Wrap"
                                               TextAlignment="Center" Margin="0,10,0,0"
                                               Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />
                                    <TextBlock Text="Loading…" Style="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,10,0,0"
                                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>

                                <Grid Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="2,0,0,12">
                                        <TextBlock Text="{Binding CurrentObjectLabel}" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"
                                                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}" />
                                    </StackPanel>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <DockPanel Grid.Column="0">
                                            <StackPanel DockPanel.Dock="Top" Margin="2,0,0,8">
                                                <TextBlock Text="Used by" Style="{StaticResource BodyStrong}" />
                                                <TextBlock Text="{Binding UsedBySummary}" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding UsedBy}" ItemTemplate="{StaticResource DependencyListTemplate}" />
                                            </ScrollViewer>
                                        </DockPanel>

                                        <DockPanel Grid.Column="2">
                                            <StackPanel DockPanel.Dock="Top" Margin="2,0,0,8">
                                                <TextBlock Text="Uses" Style="{StaticResource BodyStrong}" />
                                                <TextBlock Text="{Binding UsesSummary}" Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding Uses}" ItemTemplate="{StaticResource DependencyListTemplate}" />
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- History -->
            <TabItem Header="History">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <DataGrid ItemsSource="{Binding Runs}" AutoGenerateColumns="False" IsReadOnly="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Run time" Binding="{Binding StartedAt, Converter={StaticResource LocalDateTime}}" Width="1.6*" MinWidth="130" />
                            <DataGridTextColumn Header="Duration" Binding="{Binding DurationMs, Converter={StaticResource MsToDuration}}" Width="*" MinWidth="70" />
                            <DataGridTextColumn Header="Scanned" Binding="{Binding ObjectsScanned}" Width="*" MinWidth="64" />
                            <DataGridTextColumn Header="Changed" Binding="{Binding ChangeCount}" Width="*" MinWidth="64" />
                            <DataGridTemplateColumn Header="Skipped" Width="*" MinWidth="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- Only rendered when objects could not be scripted -->
                                        <TextBlock Text="{Binding ObjectsFailed, StringFormat={}{0:N0} skipped}"
                                                   Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   ToolTip="Objects that could not be scripted — see the Logs tab for the list">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ObjectsFailed}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Commit SHA" Binding="{Binding CommitSha}" Width="1.4*" MinWidth="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="ToolTip" Value="{Binding CommitSha}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ContentControl Content="{Binding Status}" ContentTemplate="{StaticResource StatusBadgeTemplate}"
                                                        Margin="0,4" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Configuration -->
            <TabItem Header="Configuration">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0" VerticalAlignment="Top">
                    <StackPanel>
                        <Border Background="{StaticResource PanelBrush}" CornerRadius="{StaticResource RadiusControl}"
                                Padding="16,14" Margin="0,0,0,16">
                            <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap"
                                       Text="Edit this job's source connection, selected objects, destination repository, branch, folder, and schedule in the job wizard. Changes take effect on the next run." />
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" Click="OnEdit" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconEdit}"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Edit configuration" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding ExportConfigCommand}"
                                    ToolTip="Save this job's configuration as a file you can import on another machine. Passwords and tokens are never included.">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconExport}"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Export configuration" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,10,0,0"
                                   Text="Exports reference the server and repository by name — the importing machine needs those profiles (and their credentials) set up first." />
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Logs (latest run) -->
            <TabItem Header="Logs">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Top" Content="Show technical details" IsChecked="{Binding ShowTechnicalLogs}"
                                  Margin="0,0,0,14" />
                        <DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="False" IsReadOnly="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  RowDetailsVisibilityMode="VisibleWhenSelected">
                            <!-- Selecting a row reveals its full detail — e.g. the per-object list behind
                                 an "N item(s) could not be scripted" warning. Read-only TextBox so the
                                 skip reasons can be copied. -->
                            <DataGrid.RowDetailsTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource PanelBrush}" CornerRadius="{StaticResource RadiusControl}"
                                            Padding="12,10" Margin="8,4,8,10"
                                            Visibility="{Binding Detail, Converter={StaticResource NullToVisibility}}">
                                        <TextBox Text="{Binding Detail, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                                 Background="Transparent" Padding="0"
                                                 FontFamily="{StaticResource MonoFontFamily}" FontSize="12"
                                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MaxHeight="260" />
                                    </Border>
                                </DataTemplate>
                            </DataGrid.RowDetailsTemplate>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="Auto" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="ToolTip" Value="{Binding Message}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
