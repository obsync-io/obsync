<Window x:Class="Obsync.App.Views.ScriptDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Obsync.App.Views"
        xmlns:conv="clr-namespace:Obsync.App.Converters"
        Title="{Binding Title}" Height="760" Width="1220"
        MinHeight="640" MinWidth="1000"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Obsync.App;component/Assets/Obsync_Icon.png"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <conv:ChangeTypeFilterConverter x:Key="ChangeTypeFilter" />

        <!-- One diff line: tinted row, muted line-number gutter, monospace code with word highlights. -->
        <DataTemplate x:Key="DiffRowTemplate">
            <Grid Background="{Binding Kind, Converter={StaticResource DiffRowBackground}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                        Padding="0,1,8,1">
                    <TextBlock Text="{Binding LineNumber}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                </Border>
                <TextBlock Grid.Column="1" Margin="12,1,16,1" FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="12.5" views:DiffText.Row="{Binding}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="NoWrap" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsWordWrap, RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="True">
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <!-- Virtualized, recycling code pane. Chrome-free rows: the diff tint is the only paint. -->
        <Style x:Key="DiffList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ItemTemplate" Value="{StaticResource DiffRowTemplate}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="KeyboardNavigation.TabNavigation" Value="Once" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid>
                                        <ContentPresenter />
                                        <!-- Find-in-script lands here: an outline that never shifts layout -->
                                        <Rectangle x:Name="FindHighlight" Stroke="{StaticResource AccentBrush}"
                                                   StrokeThickness="1.5" Visibility="Collapsed"
                                                   IsHitTestVisible="False" SnapsToDevicePixels="True" />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="FindHighlight" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Wrapped lines never overflow sideways, so the horizontal scrollbar goes away -->
                <DataTrigger Binding="{Binding IsWordWrap}" Value="True">
                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Segment of the Split / Unified toggle: accent-filled when selected, subtle otherwise. -->
        <Style x:Key="SegmentToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Change-type filter chip: a compact SegmentToggle that behaves like a radio. -->
        <Style x:Key="FilterChip" TargetType="RadioButton" BasedOn="{StaticResource SegmentToggle}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,4,4" />
        </Style>

        <!-- Left-rail entry container: rounded hover / accent-soft selection, no system chrome. -->
        <Style x:Key="ChangeItem" TargetType="ListBoxItem">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="{StaticResource RadiusControl}"
                                Padding="10,8" Margin="0,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PanelBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F3" Command="{Binding FindNextCommand}" />
        <KeyBinding Key="F3" Modifiers="Shift" Command="{Binding FindPreviousCommand}" />
    </Window.InputBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============================ Header ============================ -->
        <StackPanel Grid.Row="0" Margin="4,0,4,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding SelectedChange.QualifiedName}" Style="{StaticResource PageTitle}"
                           FontSize="19" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" MaxWidth="640" />
                <ContentControl Content="{Binding SelectedChange.ChangeType}"
                                ContentTemplate="{StaticResource ChangeBadgeTemplate}"
                                Margin="12,2,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock Text="{Binding ShortSha}" FontFamily="{StaticResource MonoFontFamily}" FontSize="12.5"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                <Button Style="{StaticResource IconButton}" Width="24" Height="24" Margin="4,0,0,0"
                        Command="{Binding CopyShaCommand}" ToolTip="Copy commit SHA"
                        AutomationProperties.Name="Copy commit SHA"
                        Visibility="{Binding FullSha, Converter={StaticResource NullToVisibility}}">
                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconCopy}" FontSize="12" />
                </Button>
                <TextBlock Style="{StaticResource Muted}" Text="  ·  " VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Muted}" Text="{Binding RunTimestampText}" VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource Muted}" Text="  ·  " VerticalAlignment="Center"
                           Visibility="{Binding CanOpenOnGitHub, Converter={StaticResource BoolToVisibility}}" />
                <Button Style="{StaticResource LinkButton}" Content="Open on GitHub"
                        Command="{Binding OpenOnGitHubCommand}" VerticalAlignment="Center"
                        Visibility="{Binding CanOpenOnGitHub, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </StackPanel>

        <!-- ============================ Content ============================ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left rail: this run's changed objects -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="10">
                <DockPanel>
                    <TextBox DockPanel.Dock="Top" Margin="2,2,2,10"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter by object name or path">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Resources>
                                    <VisualBrush x:Key="FilterHint" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="Filter objects…" Foreground="{StaticResource TextMutedBrush}"
                                                       FontFamily="{StaticResource AppFontFamily}" FontSize="13" Margin="10,0,0,0" />
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource FilterHint}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Change-type chips; combine with the text filter above -->
                    <WrapPanel DockPanel.Dock="Top" Margin="2,0,2,6">
                        <RadioButton Style="{StaticResource FilterChip}" Content="{Binding AllChipLabel}"
                                     AutomationProperties.Name="Show all change types"
                                     IsChecked="{Binding TypeFilter, Converter={StaticResource ChangeTypeFilter}, ConverterParameter=All}" />
                        <RadioButton Style="{StaticResource FilterChip}" Content="{Binding AddedChipLabel}"
                                     AutomationProperties.Name="Show only added objects"
                                     IsChecked="{Binding TypeFilter, Converter={StaticResource ChangeTypeFilter}, ConverterParameter=Added}" />
                        <RadioButton Style="{StaticResource FilterChip}" Content="{Binding ModifiedChipLabel}"
                                     AutomationProperties.Name="Show only modified objects"
                                     IsChecked="{Binding TypeFilter, Converter={StaticResource ChangeTypeFilter}, ConverterParameter=Modified}" />
                        <RadioButton Style="{StaticResource FilterChip}" Content="{Binding DeletedChipLabel}"
                                     AutomationProperties.Name="Show only deleted objects"
                                     IsChecked="{Binding TypeFilter, Converter={StaticResource ChangeTypeFilter}, ConverterParameter=Deleted}" />
                    </WrapPanel>

                    <ListBox ItemsSource="{Binding ChangesView}" SelectedItem="{Binding SelectedChange}"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource ChangeItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!-- Tag carries the view model into the context menu (menus sit
                                     outside the visual tree, so RelativeSource can't reach it). -->
                                <StackPanel Background="Transparent"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu FontFamily="{StaticResource AppFontFamily}" FontSize="13">
                                            <MenuItem Header="Copy object name"
                                                      Command="{Binding PlacementTarget.Tag.CopyObjectNameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="Copy path"
                                                      Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <StackPanel Orientation="Horizontal">
                                        <ContentControl Content="{Binding ChangeType}"
                                                        ContentTemplate="{StaticResource ChangeBadgeTemplate}"
                                                        VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding QualifiedName}" Style="{StaticResource BodyStrong}"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding RelativePath}" Style="{StaticResource Caption}"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Diff pane -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Pane header, two rows: file path + view toggles, then find / wrap / copy -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="16,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- The path column shrinks (trims) so the version indicator and its
                                 "Show latest" link are never pushed under the right-side toggles. -->
                            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MaxWidth="520" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding SelectedChange.RelativePath}"
                                           FontFamily="{StaticResource MonoFontFamily}" FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding SelectedChange.RelativePath}" />
                                <!-- Shown while a historical version is on screen -->
                                <TextBlock Grid.Column="1" Text="{Binding ViewedVersionText}" Style="{StaticResource Caption}"
                                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                           Visibility="{Binding ViewedVersionText, Converter={StaticResource NullToVisibility}}" />
                                <Button Grid.Column="2" Style="{StaticResource LinkButton}" Content="Show latest" Margin="8,0,0,0"
                                        VerticalAlignment="Center" Command="{Binding ShowLatestVersionCommand}"
                                        Visibility="{Binding ViewedVersionText, Converter={StaticResource NullToVisibility}}" />
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Background="{StaticResource PanelBrush}"
                                        CornerRadius="{StaticResource RadiusControl}" Padding="3" VerticalAlignment="Center"
                                        Visibility="{Binding ShowViewToggle, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton Style="{StaticResource SegmentToggle}" Content="Split"
                                                      IsChecked="{Binding IsSplitView}" />
                                        <ToggleButton Style="{StaticResource SegmentToggle}" Content="Unified" Margin="2,0,0,0"
                                                      IsChecked="{Binding IsSplitView, Converter={StaticResource InverseBool}}" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource PanelBrush}"
                                        CornerRadius="{StaticResource RadiusControl}" Padding="3" Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <ToggleButton Style="{StaticResource SegmentToggle}" IsChecked="{Binding IsHistoryVisible}"
                                                  ToolTip="Every committed version of this object, from the local copy"
                                                  AutomationProperties.Name="Toggle object history">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconHistory}"
                                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="History" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </ToggleButton>
                                </Border>
                            </StackPanel>

                            <!-- Find in script (Enter/F3 next, Shift+F3 previous, Esc clears) -->
                            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBox Width="180" VerticalAlignment="Center"
                                             Text="{Binding FindText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Find in the script as shown — Enter or F3 for the next match, Shift+F3 for the previous"
                                             AutomationProperties.Name="Find in script">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding FindNextCommand}" />
                                            <KeyBinding Key="Escape" Command="{Binding ClearFindCommand}" />
                                        </TextBox.InputBindings>
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="FindHint" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Find in script…" Foreground="{StaticResource TextMutedBrush}"
                                                                       FontFamily="{StaticResource AppFontFamily}" FontSize="13" Margin="10,0,0,0" />
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource FindHint}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <Button Style="{StaticResource IconButton}" Width="26" Height="26" Margin="4,0,0,0"
                                            Command="{Binding FindPreviousCommand}"
                                            ToolTip="Previous match (Shift+F3)" AutomationProperties.Name="Previous match">
                                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconChevronUp}" FontSize="12" />
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" Width="26" Height="26" Margin="2,0,0,0"
                                            Command="{Binding FindNextCommand}"
                                            ToolTip="Next match (Enter / F3)" AutomationProperties.Name="Next match">
                                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconChevronDown}" FontSize="12" />
                                    </Button>
                                    <TextBlock Style="{StaticResource Caption}" Text="{Binding FindCounter}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               Visibility="{Binding FindCounter, Converter={StaticResource NullToVisibility}}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource Caption}" Text="{Binding CopyStatus}"
                                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0"
                                               Visibility="{Binding CopyStatus, Converter={StaticResource NullToVisibility}}" />
                                    <Border Background="{StaticResource PanelBrush}"
                                            CornerRadius="{StaticResource RadiusControl}" Padding="3" VerticalAlignment="Center">
                                        <ToggleButton Style="{StaticResource SegmentToggle}" Content="Wrap"
                                                      IsChecked="{Binding IsWordWrap}"
                                                      ToolTip="Wrap long lines instead of scrolling sideways"
                                                      AutomationProperties.Name="Toggle word wrap" />
                                    </Border>
                                    <Button Style="{StaticResource IconButton}" Margin="6,0,0,0"
                                            Command="{Binding CopyScriptCommand}"
                                            ToolTip="Copy the script as shown (the new version for added or modified objects, the old for deleted)"
                                            AutomationProperties.Name="Copy script">
                                        <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconCopy}" FontSize="14" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <!-- Split view: both panes scroll as one (wired in code-behind) -->
                        <Grid Visibility="{Binding ShowSplit, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="OldPane" Grid.Column="0" Style="{StaticResource DiffList}"
                                     ItemsSource="{Binding OldRows}" />
                            <Border Grid.Column="1" Background="{StaticResource BorderBrush}" />
                            <ListBox x:Name="NewPane" Grid.Column="2" Style="{StaticResource DiffList}"
                                     ItemsSource="{Binding NewRows}" />
                        </Grid>

                        <!-- Unified diff / added script view / deleted script view -->
                        <ListBox x:Name="SinglePane" Style="{StaticResource DiffList}" ItemsSource="{Binding SingleRows}"
                                 Visibility="{Binding ShowSingle, Converter={StaticResource BoolToVisibility}}" />

                        <!-- Loading -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                            <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                                         Foreground="{StaticResource AccentBrush}" Background="{StaticResource PanelBrush}"
                                         BorderThickness="0" />
                            <TextBlock Text="Loading script…" Style="{StaticResource Muted}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" />
                        </StackPanel>

                        <!-- Content unavailable -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                            <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource PanelBrush}"
                                    HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconWarning}" FontSize="24" />
                            </Border>
                            <TextBlock Text="Diff not available" Style="{StaticResource SectionTitle}"
                                       HorizontalAlignment="Center" Margin="0,16,0,0" />
                            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource Muted}"
                                       TextAlignment="Center" Margin="0,6,0,0" />
                            <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Center" Margin="0,16,0,0"
                                    Command="{Binding OpenOnGitHubCommand}"
                                    Visibility="{Binding CanOpenOnGitHub, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFontFamily}" Text="{StaticResource IconOpenExternal}"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Open on GitHub" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- History rail: every committed version of the selected object, newest first -->
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="10" Width="248" Margin="16,0,0,0"
                    Visibility="{Binding IsHistoryVisible, Converter={StaticResource BoolToVisibility}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Versions" Style="{StaticResource SectionTitle}"
                               FontSize="14" Margin="2,2,2,2" />
                    <TextBlock DockPanel.Dock="Top" Text="Select a version to see what that commit changed."
                               Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="2,0,2,10" />

                    <TextBlock DockPanel.Dock="Top" Text="Loading history…" Style="{StaticResource Muted}" Margin="2,4"
                               Visibility="{Binding IsHistoryLoading, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock DockPanel.Dock="Top" Text="{Binding HistoryMessage}" Style="{StaticResource Muted}"
                               TextWrapping="Wrap" Margin="2,4"
                               Visibility="{Binding HistoryMessage, Converter={StaticResource NullToVisibility}}" />

                    <ListBox ItemsSource="{Binding HistoryVersions}" SelectedItem="{Binding SelectedVersion}"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource ChangeItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel ToolTip="{Binding Subject}">
                                    <TextBlock Text="{Binding Date.LocalDateTime, StringFormat=g}"
                                               Style="{StaticResource BodyStrong}" FontSize="12.5" />
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding ShortSha}" FontFamily="{StaticResource MonoFontFamily}"
                                                   FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding Author}" Style="{StaticResource Caption}"
                                                   Margin="8,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="130" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
