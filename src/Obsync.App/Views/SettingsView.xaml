<UserControl x:Class="Obsync.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Application and local data locations" Style="{StaticResource Muted}" Margin="0,4,0,18" />

            <!-- About -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="About" Style="{StaticResource SectionTitle}" Margin="0,0,0,16" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Version" Style="{StaticResource Caption}" VerticalAlignment="Top" Margin="0,1,0,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Version}" Style="{StaticResource BodyStrong}" />
                            <TextBlock Text="{Binding EngineVersion}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource Panel}" Background="{StaticResource AccentSoftBrush}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconCheck}"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Top" Margin="0,1,10,0" />
                            <TextBlock Text="Secrets are stored in Windows Credential Manager; the local state database never holds passwords or tokens."
                                       Style="{StaticResource Body}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Background="{StaticResource SuccessSoftBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconCheck}"
                                       Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Top" Margin="0,1,10,0" />
                            <TextBlock Text="Read-only by design — Obsync only reads metadata and object definitions. It never modifies SQL Server, never runs deployment scripts, and never requires sysadmin."
                                       Style="{StaticResource Body}" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Required SQL permissions -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Required SQL permissions" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="Obsync reads metadata and object definitions only — it never modifies the database and never needs sysadmin. Generate a least-privilege script your DBA can review and run to grant a dedicated account exactly what Obsync needs." />

                    <TextBlock Text="ACCOUNT (SQL login or DOMAIN\user)" Style="{StaticResource Caption}" />
                    <TextBox Text="{Binding PermissionAccount, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

                    <TextBlock Text="DATABASES (one per line)" Style="{StaticResource Caption}" />
                    <TextBox Text="{Binding PermissionDatabases, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="NoWrap" MinHeight="64"
                             VerticalScrollBarVisibility="Auto" Margin="0,4,0,16" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="Generate permission script" Style="{StaticResource PrimaryButton}"
                                Command="{Binding GeneratePermissionScriptCommand}" Margin="0,0,8,0" />
                        <Button Content="Copy" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CopyPermissionScriptCommand}" Margin="0,0,8,0" />
                        <Button Content="Save as .sql" Style="{StaticResource SecondaryButton}"
                                Command="{Binding SavePermissionScriptCommand}" />
                    </StackPanel>

                    <Border Style="{StaticResource Panel}"
                            Visibility="{Binding PermissionScript, Converter={StaticResource NullToVisibility}}">
                        <TextBox Text="{Binding PermissionScript, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 MinHeight="140" MaxHeight="320"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 BorderThickness="0" Background="Transparent" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Data locations -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Data locations" Style="{StaticResource SectionTitle}" Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Data folder" Style="{StaticResource Caption}" VerticalAlignment="Top" Margin="0,1,0,0" />
                        <TextBlock Grid.Column="1" Text="{Binding DataRoot}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="State database" Style="{StaticResource Caption}" VerticalAlignment="Top" Margin="0,1,0,0" />
                        <TextBlock Grid.Column="1" Text="{Binding DatabasePath}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Git workspaces" Style="{StaticResource Caption}" VerticalAlignment="Top" Margin="0,1,0,0" />
                        <TextBlock Grid.Column="1" Text="{Binding WorkspacesRoot}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Logs" Style="{StaticResource Caption}" VerticalAlignment="Top" Margin="0,1,0,0" />
                        <TextBlock Grid.Column="1" Text="{Binding LogsRoot}" Style="{StaticResource BodyStrong}" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Proxy -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Proxy" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="How Obsync reaches GitHub (API and git). SQL Server connects directly. Shared by the app and the Windows Service." />

                    <TextBlock Text="MODE" Style="{StaticResource Caption}" />
                    <ComboBox ItemsSource="{Binding ProxyModes}" SelectedItem="{Binding SelectedProxyMode}" Margin="0,4,0,16">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Visibility="{Binding IsManualProxy, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="PROXY URL (e.g. http://proxy.corp:8080)" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding ProxyUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

                        <TextBlock Text="USERNAME (OPTIONAL)" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding ProxyUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

                        <TextBlock Text="PASSWORD (LEAVE BLANK TO KEEP THE SAVED ONE)" Style="{StaticResource Caption}" />
                        <PasswordBox x:Name="ProxyPasswordBox" PasswordChanged="OnProxyPasswordChanged" Margin="0,4,0,16" />

                        <TextBlock Text="BYPASS (COMMA-SEPARATED HOSTS THAT CONNECT DIRECTLY)" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding ProxyBypass, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                    </StackPanel>

                    <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="For scheduled runs the Windows Service account often has no OS proxy — use Manual for reliable service operation." />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save proxy" Style="{StaticResource PrimaryButton}" Command="{Binding SaveProxyCommand}" Margin="0,0,8,0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        <Button Content="Test proxy" Style="{StaticResource SecondaryButton}" Command="{Binding TestProxyCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    </StackPanel>
                    <TextBlock Text="{Binding ProxyStatus}" Style="{StaticResource Muted}" Margin="0,10,0,0" TextWrapping="Wrap"
                               Visibility="{Binding ProxyStatus, Converter={StaticResource NullToVisibility}}" />
                </StackPanel>
            </Border>

            <!-- Diagnostics + support bundle -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Diagnostics" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="Check SQL Server, GitHub, Git, disk space, and the Obsync service — then export a support bundle if you need help." />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Run diagnostics" Style="{StaticResource PrimaryButton}"
                                Command="{Binding RunDiagnosticsCommand}" Margin="0,0,8,0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                        <Button Content="Export support bundle" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportSupportBundleCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Diagnostics}"
                                  Visibility="{Binding Diagnostics.Count, Converter={StaticResource CountToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="Auto" MinWidth="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontWeight="Bold" VerticalAlignment="Top">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x2715;" />
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pass">
                                                        <Setter Property="Text" Value="&#x2713;" />
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                        <Setter Property="Text" Value="!" />
                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource BodyStrong}" Margin="0,0,12,0" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" Style="{StaticResource Muted}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding DiagnosticsSummary}" Style="{StaticResource Muted}" Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding DiagnosticsSummary, Converter={StaticResource NullToVisibility}}" />
                    <TextBlock Text="The support bundle includes versions, config, diagnostics, and recent logs. Secrets are never included."
                               Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <!-- Recent activity (audit trail) -->
            <Border Style="{StaticResource Card}" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="Recent activity" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="Who did what, attributed to the Windows identity that performed the action." />

                    <ItemsControl ItemsSource="{Binding RecentActivity}"
                                  Visibility="{Binding RecentActivity.Count, Converter={StaticResource CountToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource BodyStrong}" TextWrapping="Wrap">
                                            <Run Text="{Binding Action, Converter={StaticResource EnumDisplay}, Mode=OneWay}" />
                                            <Run Text="{Binding EntityName, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding Actor}" Style="{StaticResource Muted}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"
                                               Text="{Binding OccurredAt, Converter={StaticResource LocalDateTime}}"
                                               Style="{StaticResource Muted}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No activity recorded yet.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentActivity.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
