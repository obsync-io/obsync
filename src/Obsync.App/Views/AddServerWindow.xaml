<Window x:Class="Obsync.App.Views.AddServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Icon="pack://application:,,,/Obsync.App;component/Assets/Obsync_Icon.png"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="28">
        <StackPanel>
            <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Connect Obsync to a SQL Server instance." Style="{StaticResource Muted}" Margin="0,4,0,20" />

            <TextBlock Text="DISPLAY NAME" Style="{StaticResource Caption}" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />

            <TextBlock Text="SERVER NAME" Style="{StaticResource Caption}" />
            <TextBox Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,3" />
            <TextBlock Text="e.g. HOST, HOST\INSTANCE, or HOST,1433" Style="{StaticResource Caption}" Margin="0,0,0,16" />

            <TextBlock Text="AUTHENTICATION" Style="{StaticResource Caption}" />
            <ComboBox ItemsSource="{Binding AuthModes}" SelectedItem="{Binding AuthenticationMode}" Margin="0,4,0,16">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplay}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Windows identity (auto-detected) -->
            <Border Style="{StaticResource Panel}" Margin="0,0,0,16"
                    Visibility="{Binding IsWindowsAuth, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource Icon}" Text="{StaticResource IconCheck}"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Connecting as" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding WindowsIdentityName}" Style="{StaticResource BodyStrong}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SQL login credentials -->
            <StackPanel Visibility="{Binding IsSqlLogin, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="USERNAME" Style="{StaticResource Caption}" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,16" />
                <TextBlock Text="{Binding PasswordHint}" Style="{StaticResource Caption}" />
                <PasswordBox x:Name="PasswordBox" PasswordChanged="OnPasswordChanged" Margin="0,4,0,16" />
            </StackPanel>

            <!-- Advanced options -->
            <Border Style="{StaticResource Panel}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Advanced" Style="{StaticResource Caption}" Margin="0,0,0,10" />
                    <CheckBox Content="Encrypt connection" IsChecked="{Binding Encrypt}" />
                    <CheckBox Content="Trust server certificate" IsChecked="{Binding TrustServerCertificate}" Margin="0,8,0,12" />
                    <TextBlock Text="CONNECTION TIMEOUT (SECONDS)" Style="{StaticResource Caption}" />
                    <TextBox Text="{Binding ConnectTimeoutSeconds}" Width="110" HorizontalAlignment="Left" Margin="0,4,0,0"
                             MaxLength="4" PreviewTextInput="OnDigitsOnly" DataObject.Pasting="OnPasteDigitsOnly" />
                </StackPanel>
            </Border>

            <!-- Test result -->
            <TextBlock Text="{Binding TestResult}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,14"
                       Visibility="{Binding TestResult, Converter={StaticResource NullToVisibility}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Body}">
                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TestSucceeded}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource SubtleButton}" Click="OnCancel" Margin="0,0,8,0" />
                <Button Content="Test connection" Style="{StaticResource SecondaryButton}" Command="{Binding TestCommand}" Margin="0,0,8,0"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                <Button Content="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
